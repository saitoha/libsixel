	-$(am__rm_f) $(top_builddir)/gdk-pixbuf-loader/$(am__dirstamp)
	-$(am__rm_f) cli/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) cli/$(am__dirstamp)
	-$(am__rm_f) filter/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) filter/$(am__dirstamp)
