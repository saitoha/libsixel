pkgpythondir = @pkgpythondir@
prefix = @prefix@
program_transform_name = @program_transform_name@
psdir = @psdir@
pyexecdir = @pyexecdir@
pythondir = @pythondir@
runstatedir = @runstatedir@
sbindir = @sbindir@
sharedstatedir = @sharedstatedir@
srcdir = @srcdir@
sysconfdir = @sysconfdir@
target_alias = @target_alias@
top_build_prefix = @top_build_prefix@
top_builddir = @top_builddir@
top_srcdir = @top_srcdir@
zshcompletiondir = @zshcompletiondir@
@CFLAGS_HAVE_COVERAGE_TRUE@MAYBE_COVERAGE = --coverage
@COND_GCOV_TRUE@MAYBE_COVERAGE = --coverage
AMALGAMATION_SIXEL = $(top_builddir)/amalgamation/sixel.c
@WANT_AMALGAMATED_TOOLS_TRUE@BUILT_SOURCES = $(AMALGAMATION_SIXEL)
TESTS = @SIXEL_CHECK_TESTS@
SERIAL_TESTS = \
    cli/aborttrace/0001_img2sixel_aborttrace.t

COPY_TESTS = $(TESTS)
TEST_EXTENSIONS = .t .py .rb .pl .php
HELPER_FILES = \
    docs/consistency/list_envvars.sh \
    bindings/python/_taptest.py \
    bindings/check-loader-setopt-sync.sh \
    bindings/ruby/_coverage_runner.rb \
    bindings/ruby/_coverage_to_lcov.rb \
    bindings/perl/_coverage_to_lcov.pl \
    bindings/php/_coverage_runner.php \
    bindings/php/_coverage_to_lcov.php

ARTIFACT_ROOT = $(abs_builddir)/_artifacts
SIXEL_TEST_MACOS_PRODUCT_VERSION := $(shell sw_vers -productVersion 2>/dev/null || printf "")
# Keep executable suffix in sync with the configured target so TAP
# wrappers can resolve cross-built Windows binaries under Wine.
AM_TESTS_ENVIRONMENT = ARTIFACT_ROOT='$(ARTIFACT_ROOT)'; export \
	ARTIFACT_ROOT; TOP_SRCDIR='$(abs_top_srcdir)'; export \
	TOP_SRCDIR; TOP_BUILDDIR='$(abs_top_builddir)'; export \
	TOP_BUILDDIR; SIXEL_BIN_EXT='@EXEEXT@'; export SIXEL_BIN_EXT; \
	SIXEL_TSAN_BUILD='@SIXEL_TSAN_BUILD@'; export \
	SIXEL_TSAN_BUILD; SIXEL_MSAN_BUILD='@SIXEL_MSAN_BUILD@'; \
	export SIXEL_MSAN_BUILD; CROSS_COMPILING='@cross_compiling@'; \
	export CROSS_COMPILING; ENABLE_PYTHON='@ENABLE_PYTHON@'; \
	export ENABLE_PYTHON; ENABLE_RUBY='@ENABLE_RUBY@'; export \
	ENABLE_RUBY; ENABLE_PERL='@ENABLE_PERL@'; export ENABLE_PERL; \
	ENABLE_PHP='@ENABLE_PHP@'; export ENABLE_PHP; \
	SIXEL_CONFIGURED_RUBY='@RUBY@'; export SIXEL_CONFIGURED_RUBY; \
	SIXEL_CONFIGURED_PHP='@PHP@'; export SIXEL_CONFIGURED_PHP; \
	RUNTIME_SHLIBPATH_VAR='@SIXEL_LIBTOOL_SHLIBPATH_VAR@'; export \
	RUNTIME_SHLIBPATH_VAR; \
	RUNTIME_SHLIBPATH_SEP='@SIXEL_LIBTOOL_PATH_SEPARATOR@'; export \
	RUNTIME_SHLIBPATH_SEP; \
	SIXEL_SHLIBPATH_OVERRIDES_RUNPATH='@SIXEL_SHLIBPATH_OVERRIDES_RUNPATH@'; \
	export SIXEL_SHLIBPATH_OVERRIDES_RUNPATH; \
	SIXEL_TEST_ADDITIOANL_PATH='@SIXEL_TEST_ADDITIOANL_PATH@'; \
	export SIXEL_TEST_ADDITIOANL_PATH; \
	SIXEL_TEST_MACOS_PRODUCT_VERSION='$(SIXEL_TEST_MACOS_PRODUCT_VERSION)'; \
	export SIXEL_TEST_MACOS_PRODUCT_VERSION; \
	SIXEL_TEST_HOST_ARCH='@host_cpu@'; export \
	SIXEL_TEST_HOST_ARCH;
TESTS_COMMON_CPPFLAGS_VAL = $(AM_CPPFLAGS) \
       -I$(top_builddir) -I$(top_builddir)/include \
       -I$(top_srcdir)/include -I$(top_srcdir)/src \
       -I$(top_srcdir)

