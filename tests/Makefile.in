@ENABLE_GDK_PIXBUF_LOADER_TRUE@gdk_pixbuf_loader_test_gdk_pixbuf_loader_SOURCES = \
@ENABLE_GDK_PIXBUF_LOADER_TRUE@    gdk-pixbuf-loader/test-gdk-pixbuf-loader.c \
@ENABLE_GDK_PIXBUF_LOADER_TRUE@    $(top_srcdir)/gdk-pixbuf-loader/sixel-pixbuf-loader.c

@ENABLE_GDK_PIXBUF_LOADER_TRUE@gdk_pixbuf_loader_test_gdk_pixbuf_loader_CPPFLAGS = $(AM_CPPFLAGS) \
@ENABLE_GDK_PIXBUF_LOADER_TRUE@        -I$(top_builddir)/include \
@ENABLE_GDK_PIXBUF_LOADER_TRUE@        -I$(top_srcdir)/include \
@ENABLE_GDK_PIXBUF_LOADER_TRUE@        -I$(top_srcdir)/src \
@ENABLE_GDK_PIXBUF_LOADER_TRUE@        $(GDK_PIXBUF_CFLAGS) \
@ENABLE_GDK_PIXBUF_LOADER_TRUE@        -DGDK_PIXBUF_ENABLE_BACKEND

@ENABLE_GDK_PIXBUF_LOADER_TRUE@gdk_pixbuf_loader_test_gdk_pixbuf_loader_LDADD = \
@ENABLE_GDK_PIXBUF_LOADER_TRUE@        $(top_builddir)/src/libsixel.la \
@ENABLE_GDK_PIXBUF_LOADER_TRUE@        $(GDK_PIXBUF_LIBS)

TEST_EXTENSIONS = .t
HELPER_FILES = cli/t/converters-common.t \
       python/lib/common.sh

ARTIFACT_ROOT = $(abs_builddir)/_artifacts
AM_TESTS_ENVIRONMENT = ARTIFACT_ROOT='$(ARTIFACT_ROOT)'; export \
	ARTIFACT_ROOT; TOP_SRCDIR='$(abs_top_srcdir)'; export \
	TOP_SRCDIR; TOP_BUILDDIR='$(abs_top_builddir)'; export \
	TOP_BUILDDIR;
TEST_LOG_DRIVER = env AM_TAP_AWK='$(AWK)' $(SHELL) $(top_srcdir)/build-aux/tap-driver.sh
AM_TEST_LOG_DRIVER_FLAGS = --comments
LOG_COMPILER = $(builddir)/tools/with-timeout.sh
AM_TEST_TIMEOUT = 300
AM_LOG_FLAGS = --timeout=$(AM_TEST_TIMEOUT)
EXTRA_DIST = $(TESTS) $(HELPER_FILES) tools/with-timeout.sh \
             lsqa_regression.sh \
             data/baseline/*.json data/inputs/formats/* \
             data/resolutions/*.png data/corrupted/* \
             filter/filter_tests.c filter/filter_sample_tests.c \
             filter/filter_resize_tests.c filter/filter_colors_tests.c \
             filter/filter_lookup_tests.c filter/filter_final_merge_tests.c \
             filter/filter_vpte_tests.c filter/filter_load_tests.c \
             filter/filter_dither_tests.c filter/filter_encode_tests.c \
             filter/filter_test_common.h

# Avoid deleting the in-tree timeout wrapper when building in the source
# directory. The wrapper is regenerated for out-of-tree builds, so remove it
# only in that case to prevent accidental loss from "make clean".
CLEANFILES = 
all: all-am

.SUFFIXES:
.SUFFIXES: .c .lo .log .o .obj .t .t$(EXEEXT) .trs
$(srcdir)/Makefile.in: @MAINTAINER_MODE_TRUE@ $(srcdir)/Makefile.am  $(am__configure_deps)
	@for dep in $?; do \
	  case '$(am__configure_deps)' in \
	    *$$dep*) \
	      ( cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh ) \
	        && { if test -f $@; then exit 0; else break; fi; }; \
	      exit 1;; \
	  esac; \
	done; \
	echo ' cd $(top_srcdir) && $(AUTOMAKE) --foreign tests/Makefile'; \
	$(am__cd) $(top_srcdir) && \
	  $(AUTOMAKE) --foreign tests/Makefile
Makefile: $(srcdir)/Makefile.in $(top_builddir)/config.status
	@case '$?' in \
	  *config.status*) \
	    cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh;; \
	  *) \
	    echo ' cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__maybe_remake_depfiles)'; \
	    cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__maybe_remake_depfiles);; \
	esac;

$(top_builddir)/config.status: $(top_srcdir)/configure $(CONFIG_STATUS_DEPENDENCIES)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh

$(top_srcdir)/configure: @MAINTAINER_MODE_TRUE@ $(am__configure_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(ACLOCAL_M4): @MAINTAINER_MODE_TRUE@ $(am__aclocal_m4_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(am__aclocal_m4_deps):

clean-checkPROGRAMS:
	$(am__rm_f) $(check_PROGRAMS)
	test -z "$(EXEEXT)" || $(am__rm_f) $(check_PROGRAMS:$(EXEEXT)=)
gdk-pixbuf-loader/$(am__dirstamp):
	@$(MKDIR_P) gdk-pixbuf-loader
	@: >>gdk-pixbuf-loader/$(am__dirstamp)
gdk-pixbuf-loader/$(DEPDIR)/$(am__dirstamp):
	@$(MKDIR_P) gdk-pixbuf-loader/$(DEPDIR)
	@: >>gdk-pixbuf-loader/$(DEPDIR)/$(am__dirstamp)
gdk-pixbuf-loader/test_gdk_pixbuf_loader-test-gdk-pixbuf-loader.$(OBJEXT):  \
	gdk-pixbuf-loader/$(am__dirstamp) \
	gdk-pixbuf-loader/$(DEPDIR)/$(am__dirstamp)
$(top_builddir)/gdk-pixbuf-loader/$(am__dirstamp):
	@$(MKDIR_P) $(top_builddir)/gdk-pixbuf-loader
	@: >>$(top_builddir)/gdk-pixbuf-loader/$(am__dirstamp)
$(top_builddir)/gdk-pixbuf-loader/$(DEPDIR)/$(am__dirstamp):
	@$(MKDIR_P) $(top_builddir)/gdk-pixbuf-loader/$(DEPDIR)
	@: >>$(top_builddir)/gdk-pixbuf-loader/$(DEPDIR)/$(am__dirstamp)
$(top_builddir)/gdk-pixbuf-loader/gdk_pixbuf_loader_test_gdk_pixbuf_loader-sixel-pixbuf-loader.$(OBJEXT):  \
	$(top_builddir)/gdk-pixbuf-loader/$(am__dirstamp) \
	$(top_builddir)/gdk-pixbuf-loader/$(DEPDIR)/$(am__dirstamp)

gdk-pixbuf-loader/test-gdk-pixbuf-loader$(EXEEXT): $(gdk_pixbuf_loader_test_gdk_pixbuf_loader_OBJECTS) $(gdk_pixbuf_loader_test_gdk_pixbuf_loader_DEPENDENCIES) $(EXTRA_gdk_pixbuf_loader_test_gdk_pixbuf_loader_DEPENDENCIES) gdk-pixbuf-loader/$(am__dirstamp)
	@rm -f gdk-pixbuf-loader/test-gdk-pixbuf-loader$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(gdk_pixbuf_loader_test_gdk_pixbuf_loader_OBJECTS) $(gdk_pixbuf_loader_test_gdk_pixbuf_loader_LDADD) $(LIBS)

mostlyclean-compile:
	-rm -f *.$(OBJEXT)
	-rm -f $(top_builddir)/gdk-pixbuf-loader/*.$(OBJEXT)
	-rm -f gdk-pixbuf-loader/*.$(OBJEXT)

distclean-compile:
	-rm -f *.tab.c

@AMDEP_TRUE@@am__include@ @am__quote@$(top_builddir)/gdk-pixbuf-loader/$(DEPDIR)/gdk_pixbuf_loader_test_gdk_pixbuf_loader-sixel-pixbuf-loader.Po@am__quote@ # am--include-marker
@AMDEP_TRUE@@am__include@ @am__quote@gdk-pixbuf-loader/$(DEPDIR)/test_gdk_pixbuf_loader-test-gdk-pixbuf-loader.Po@am__quote@ # am--include-marker

$(am__depfiles_remade):
	@$(MKDIR_P) $(@D)
	@: >>$@

am--depfiles: $(am__depfiles_remade)

.c.o:
@am__fastdepCC_TRUE@	$(AM_V_CC)depbase=`echo $@ | sed 's|[^/]*$$|$(DEPDIR)/&|;s|\.o$$||'`;\
@am__fastdepCC_TRUE@	$(COMPILE) -MT $@ -MD -MP -MF $$depbase.Tpo -c -o $@ $< &&\
@am__fastdepCC_TRUE@	$(am__mv) $$depbase.Tpo $$depbase.Po
@AMDEP_TRUE@@am__fastdepCC_FALSE@	$(AM_V_CC)source='$<' object='$@' libtool=no @AMDEPBACKSLASH@
@AMDEP_TRUE@@am__fastdepCC_FALSE@	DEPDIR=$(DEPDIR) $(CCDEPMODE) $(depcomp) @AMDEPBACKSLASH@
@am__fastdepCC_FALSE@	$(AM_V_CC@am__nodep@)$(COMPILE) -c -o $@ $<

.c.obj:
@am__fastdepCC_TRUE@	$(AM_V_CC)depbase=`echo $@ | sed 's|[^/]*$$|$(DEPDIR)/&|;s|\.obj$$||'`;\
@am__fastdepCC_TRUE@	$(COMPILE) -MT $@ -MD -MP -MF $$depbase.Tpo -c -o $@ `$(CYGPATH_W) '$<'` &&\
@am__fastdepCC_TRUE@	$(am__mv) $$depbase.Tpo $$depbase.Po
@AMDEP_TRUE@@am__fastdepCC_FALSE@	$(AM_V_CC)source='$<' object='$@' libtool=no @AMDEPBACKSLASH@
@AMDEP_TRUE@@am__fastdepCC_FALSE@	DEPDIR=$(DEPDIR) $(CCDEPMODE) $(depcomp) @AMDEPBACKSLASH@
@am__fastdepCC_FALSE@	$(AM_V_CC@am__nodep@)$(COMPILE) -c -o $@ `$(CYGPATH_W) '$<'`

.c.lo:
@am__fastdepCC_TRUE@	$(AM_V_CC)depbase=`echo $@ | sed 's|[^/]*$$|$(DEPDIR)/&|;s|\.lo$$||'`;\
@am__fastdepCC_TRUE@	$(LTCOMPILE) -MT $@ -MD -MP -MF $$depbase.Tpo -c -o $@ $< &&\
@am__fastdepCC_TRUE@	$(am__mv) $$depbase.Tpo $$depbase.Plo
@AMDEP_TRUE@@am__fastdepCC_FALSE@	$(AM_V_CC)source='$<' object='$@' libtool=yes @AMDEPBACKSLASH@
@AMDEP_TRUE@@am__fastdepCC_FALSE@	DEPDIR=$(DEPDIR) $(CCDEPMODE) $(depcomp) @AMDEPBACKSLASH@
@am__fastdepCC_FALSE@	$(AM_V_CC@am__nodep@)$(LTCOMPILE) -c -o $@ $<

