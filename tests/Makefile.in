@am__EXEEXT_TRUE@	$(am__check_pre) $(RB_LOG_DRIVER) --test-name "$$f" \
@am__EXEEXT_TRUE@	--log-file $$b.log --trs-file $$b.trs \
@am__EXEEXT_TRUE@	$(am__common_driver_flags) $(AM_RB_LOG_DRIVER_FLAGS) $(RB_LOG_DRIVER_FLAGS) -- $(RB_LOG_COMPILE) \
@am__EXEEXT_TRUE@	"$$tst" $(AM_TESTS_FD_REDIRECT)
@am__EXEEXT_TRUE@.pl$(EXEEXT).log:
