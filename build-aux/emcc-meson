#!/bin/sh -e

prev=
for a in "$@"; do
  if [ "$prev" = "-o" ]; then
    case "$a" in
      # Meson changed the sanity check output name in newer releases.
      # Handle both legacy and current forms to keep setup portable.
      sanitycheck*.exe|sanity_check_for_*.exe)
        cp "$(which true)" "$a"
        exit 0
        ;;
    esac
    out="$a"
  fi
  prev="$a"
done

emcc "$@"
ret=$?

if test "${out}" != "${bin:="${out%.js}"}"; then
  echo "${out} -> ${bin}" >&2
  #mkdir -pv "$(dirname "${bin}")"
  echo '#!/usr/bin/env node' > "${bin}"
  cat "${out}" >> "${bin}"
  chmod +x "${bin}"
fi

exit $ret
