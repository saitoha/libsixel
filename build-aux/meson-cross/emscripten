[binaries]
c = 'emcc-meson'
ar = 'emar'
ranlib = 'emranlib'
strip = 'emstrip'
nm = 'llvm-nm'

[properties]
exe_suffix = ''
needs_exe_wrapper = true
exe_wrapper = 'node'

[built-in options]
c_args = ['-O3', '-g0', '-msimd128']

[host_machine]
system = 'emscripten'
cpu_family = 'wasm32'
cpu = 'wasm32'
endian = 'little'
