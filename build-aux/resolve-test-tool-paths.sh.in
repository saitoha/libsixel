#!/bin/sh
# Resolve test helper tool paths and print shell-safe KEY='value' assignments.
#
# This script centralizes the tool path detection used by tests/check-TESTS.
# Output format is designed for:
#   eval "$(resolve-test-tool-paths.sh <top_builddir> <key-list>)"

set -eu

if [ "$#" -ne 2 ]; then
    echo "Usage: $0 <top_builddir> <key-list-file>" >&2
    exit 1
fi

top_builddir=$1
key_list_file=$2

if [ ! -f "$key_list_file" ]; then
    echo "Key list not found: $key_list_file" >&2
    exit 1
fi

quote_single() {
    escaped=$(printf "%s" "$1" | sed "s/'/'\"'\"'/g")
    printf "'%s'" "$escaped"
}

emit_assignment() {
    key=$1
    value=$2
    quoted_value=$(quote_single "$value")
    printf "%s=%s\n" "$key" "$quoted_value"
}

resolve_test_tool_path() {
    top_path=$1
    real_path=$2
    prefer_wrapper_path=$3
    magic=

    if [ -f "$top_path" ]; then
        # shellcheck disable=SC2046
        set -- $(dd if="$top_path" bs=1 count=2 2>/dev/null | od -An -tx1)
        magic="${1-}${2-}"
        if [ "$magic" = "2321" ] && [ -f "$real_path" ]; then
            if [ "$prefer_wrapper_path" = "yes" ]; then
                printf '%s\n' "$top_path"
            else
                printf '%s\n' "$real_path"
            fi
        else
            printf '%s\n' "$top_path"
        fi
        return 0
    fi

    if [ -f "$real_path" ]; then
        printf '%s\n' "$real_path"
    else
        printf '%s\n' "$top_path"
    fi
}

shlibpath_overrides_runpath=$(
    awk -F= '/^shlibpath_overrides_runpath=/{gsub(/\047/, "", $2); print $2; exit}' \
        "$top_builddir/libtool" 2>/dev/null || true
)

prefer_wrapper=no
if [ "$shlibpath_overrides_runpath" != "yes" ]; then
    prefer_wrapper=yes
fi

IMG2SIXEL_PATH=$(resolve_test_tool_path \
    "$top_builddir/converters/img2sixel@EXEEXT@" \
    "$top_builddir/converters/@SIXEL_LIBTOOL_OBJDIR@/img2sixel@EXEEXT@" \
    "$prefer_wrapper")
SIXEL2PNG_PATH=$(resolve_test_tool_path \
    "$top_builddir/converters/sixel2png@EXEEXT@" \
    "$top_builddir/converters/@SIXEL_LIBTOOL_OBJDIR@/sixel2png@EXEEXT@" \
    "$prefer_wrapper")
LSQA_PATH=$(resolve_test_tool_path \
    "$top_builddir/assessment/lsqa@EXEEXT@" \
    "$top_builddir/assessment/@SIXEL_LIBTOOL_OBJDIR@/lsqa@EXEEXT@" \
    "$prefer_wrapper")
TEST_RUNNER_PATH=$(resolve_test_tool_path \
    "$top_builddir/tests/test_runner@EXEEXT@" \
    "$top_builddir/tests/@SIXEL_LIBTOOL_OBJDIR@/test_runner@EXEEXT@" \
    "$prefer_wrapper")
LIBSIXEL_LIBDIR="$top_builddir/src/.libs"
if [ ! -d "$LIBSIXEL_LIBDIR" ]; then
    LIBSIXEL_LIBDIR="$top_builddir/src"
fi

keys=$(awk '
    /^[[:space:]]*($|#)/ { next }
    {
        gsub(/^[[:space:]]+/, "")
        gsub(/[[:space:]]+$/, "")
        if ($0 != "") {
            print $0
        }
    }
' "$key_list_file")

for key in $keys; do
    value=
    case "$key" in
        IMG2SIXEL_PATH) value=$IMG2SIXEL_PATH ;;
        SIXEL2PNG_PATH) value=$SIXEL2PNG_PATH ;;
        LSQA_PATH) value=$LSQA_PATH ;;
        TEST_RUNNER_PATH) value=$TEST_RUNNER_PATH ;;
        LIBSIXEL_LIBDIR) value=$LIBSIXEL_LIBDIR ;;
        *)
            echo "Unknown key in list: $key" >&2
            exit 1
            ;;
    esac
    emit_assignment "$key" "$value"
done
