#
# pcc wrapper for Autotools builds.
#
# Keep this wrapper minimal: unlike Meson we do not need compiler identity
# spoofing.  We only paper over pcc/glibc integration issues seen on newer
# Linux runners.

import os
import sys


REAL_PCC = os.environ.get("SIXEL_REAL_PCC", "pcc")
def main():
    args = sys.argv[1:]

    # Newer glibc headers can use GNU attributes that pcc rejects.
    # Ubuntu 24.04 currently fails on `__cold__`.
    if os.environ.get("SIXEL_PCC_KEEP_ATTRIBUTES", "") != "1":
        args = ["-D__cold__="] + args

    os.execvp(REAL_PCC, [REAL_PCC] + args)
    return 127


if __name__ == "__main__":
    raise SystemExit(main())
