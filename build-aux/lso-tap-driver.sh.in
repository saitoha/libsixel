set -u

# Prefer configure-time detected test shell. Allow runtime override for
# troubleshooting and platform-specific experiments.
: "${SIXEL_TEST_SHELL:=@SIXEL_TEST_SHELL@}"
: "${SIXEL_TEST_PYTHON:=}"
: "${SIXEL_TEST_RUBY:=}"
: "${SIXEL_TEST_RUBY_GEM_HOME:=}"

test_name=
log_file=
trs_file=
ignore_exit=no
comments=no
test_timeout=
color_tests=
expect_failure=
hard_errors=no

usage() {
  cat <<'EOF' >&2
Usage:
  lso-tap-driver.sh --test-name NAME --log-file PATH.log --trs-file PATH.trs
    [--ignore-exit] [--comments] [--timeout SECONDS]
    [--] TEST-SCRIPT [ARGS...]
EOF
  exit 2
}

# Parse options required by Automake custom test driver protocol.
# (Automake mandates --test-name/--log-file/--trs-file.) :contentReference[oaicite:2]{index=2}
while [ $# -gt 0 ]; do
  case "$1" in
    --help) usage ;;
    --test-name) test_name=${2-}; shift ;;
    --log-file)  log_file=${2-}; shift ;;
    --trs-file)  trs_file=${2-}; shift ;;
    --ignore-exit) ignore_exit=yes ;;
    --comments) comments=yes ;;
    --timeout) test_timeout=${2-}; shift ;;
    --timeout=*) test_timeout=${1#*=} ;;
    --color-tests) color_tests=${2-}; shift ;;
    --color-tests=*) color_tests=${1#*=} ;;
    --enable-hard-errors)
      case ${2-} in
        ""|--*) hard_errors=yes ;;
        *) hard_errors=$2; shift ;;
      esac
      ;;
    --enable-hard-errors=*) hard_errors=${1#*=} ;;
    --expect-failure) expect_failure=${2-}; shift ;;
    --expect-failure=*) expect_failure=${1#*=} ;;
    --) shift; break ;;
    -*) echo "lso-tap-driver.sh: invalid option: $1" >&2; usage ;;
    *) break ;;
  esac
  shift
done

[ -n "${test_name}" ] || { echo "lso-tap-driver.sh: missing --test-name" >&2; usage; }
[ -n "${log_file}" ]  || { echo "lso-tap-driver.sh: missing --log-file" >&2; usage; }
[ -n "${trs_file}" ]  || { echo "lso-tap-driver.sh: missing --trs-file" >&2; usage; }
[ $# -ge 1 ] || { echo "lso-tap-driver.sh: missing TEST-SCRIPT" >&2; usage; }

: "${TOP_SRCDIR:=@top_srcdir@}"
: "${AM_TAP_AWK:=awk}"
: "${LSO_TAP_TIMER_BIN:=@top_builddir@/tools/lso-timer@EXEEXT@}"
: "${LSO_TAP_TIMER_SRC:=@top_srcdir@/tools/lso-timer@EXEEXT@}"
: "${LSO_TAP_TIMER_BUILD:=@top_builddir@/tools/lso-timer@EXEEXT@}"
: "${LSO_TAP_TIMEOUT_BIN:=@top_builddir@/tools/lso-timeout@EXEEXT@}"
: "${LSO_TAP_TIMEOUT_SRC:=@top_srcdir@/tools/lso-timeout@EXEEXT@}"
: "${LSO_TAP_TIMEOUT_BUILD:=@top_builddir@/tools/lso-timeout@EXEEXT@}"
timeout_budget=${test_timeout:-90}
kill_delay=10

test_script=$1
test_name_base=${test_name##*[/\\]}
test_dir=${test_script%[/\\]*}
if [ "${test_dir}" = "${test_script}" ]; then
  test_dir=.
fi
category_name=${test_dir#*tests/}
artifact_root="${TOP_BUILDDIR}/tests/_artifacts"
ARTIFACT_LOCAL_DIR="${artifact_root}/${category_name}/${test_name_base}"
export test_dir
export category_name
export ARTIFACT_LOCAL_DIR
mkdir -p "${ARTIFACT_LOCAL_DIR}"

timestamp_millis() {
  if [ -x "$LSO_TAP_TIMER_BIN" ]; then
    ${SIXEL_RUNTIME-} "$LSO_TAP_TIMER_BIN" && return
  fi

  if [ -x "$LSO_TAP_TIMER_BUILD" ]; then
    ${SIXEL_RUNTIME-} "$LSO_TAP_TIMER_BUILD" && return
  fi

  if [ -x "$LSO_TAP_TIMER_SRC" ]; then
    ${SIXEL_RUNTIME-} "$LSO_TAP_TIMER_SRC" && return
  fi

  date +%s
}

select_timeout_bin() {
  if command -v timeout >/dev/null 2>&1; then
    echo "timeout"
    return
  fi
  if command -v gtimeout >/dev/null 2>&1; then
    echo "gtimeout"
    return
  fi
  if [ -n "${SIXEL_RUNTIME-}" ]; then
    echo ""
    return
  fi
  if [ -x "$LSO_TAP_TIMEOUT_BIN" ]; then
    echo "$LSO_TAP_TIMEOUT_BIN"
    return
  fi
  if [ -x "$LSO_TAP_TIMEOUT_BUILD" ]; then
    echo "$LSO_TAP_TIMEOUT_BUILD"
    return
  fi
  if [ -x "$LSO_TAP_TIMEOUT_SRC" ]; then
    echo "$LSO_TAP_TIMEOUT_SRC"
    return
  fi

  echo ""
}

run_with_helper() {
  helper=$1
  shift
  ${helper} -k "${kill_delay}s" "${timeout_budget}s" "$@"
  status=$?
  if [ "$status" -eq 124 ] || [ "$status" -eq 137 ]; then
    echo "Bail out! timeout after ${timeout_budget}s" >&2
  fi
  return "$status"
}

run_with_timeout() {
  helper_bin=$(select_timeout_bin)
  test_path=$1
  shift

  case "$test_path" in
    *.py)
      run_desc="python ${test_path}"
      if [ -n "${SIXEL_TEST_PYTHON}" ] && [ -x "${SIXEL_TEST_PYTHON}" ]; then
        set -- "$SIXEL_TEST_PYTHON" "$test_path" "$@"
      else
        printf '%s\n' '1..0 # SKIP python test interpreter is unavailable' >"$log_file"
        cat >"$trs_file" <<'EOF'
:test-result: SKIP
:global-test-result: SKIP
:recheck: yes
:copy-in-global-log: no
EOF
        return 0
      fi
      ;;
    *.rb)
      run_desc="ruby ${test_path}"
      if [ -n "${SIXEL_TEST_RUBY}" ] && [ -x "${SIXEL_TEST_RUBY}" ]; then
        if [ -n "${SIXEL_TEST_RUBY_GEM_HOME}" ]; then
          GEM_HOME="${SIXEL_TEST_RUBY_GEM_HOME}" \
          GEM_PATH="${SIXEL_TEST_RUBY_GEM_HOME}" \
            export GEM_HOME GEM_PATH
        fi
        set -- "$SIXEL_TEST_RUBY" "$test_path" "$@"
      else
        printf '%s\n' '1..0 # SKIP ruby test interpreter is unavailable' >"$log_file"
        cat >"$trs_file" <<'EOF'
:test-result: SKIP
:global-test-result: SKIP
:recheck: yes
:copy-in-global-log: no
EOF
        return 0
      fi
      ;;
    *)
      run_desc="shell ${test_path}"
      set -- "$SIXEL_TEST_SHELL" "$test_path" "$@"
      ;;
  esac

  echo "# lso-tap-driver: ${run_desc}"

  if [ -n "$helper_bin" ]; then
    run_with_helper "$helper_bin" "$@"
    return $?
  fi

  "$@"
  return $?
}

# Run the test script, capture all output in .log (format free). :contentReference[oaicite:3]{index=3}
# We don't stream to console; Automake shows progress separately.
# If you want streaming, do it in the test itself (or add tee here).
if test "$(command -v time)" = time; then
    # use builtin time
    time_begin=0
    time_end=$( TIMEFORMAT='%R'; { time run_with_timeout "$@" >"$log_file" 2>&1; } 2>&1 )
    rc=$?
else
    time_begin=$(timestamp_millis)
    run_with_timeout "$@" >"$log_file" 2>&1
    rc=$?
    time_end=$(timestamp_millis)
fi

# Generate .trs (reStructuredText fields), at minimum :test-result: fields. :contentReference[oaicite:4]{index=4}
# Also write :global-test-result:, :recheck:, :copy-in-global-log: for convenience
# (Automake recognizes these fields). :contentReference[oaicite:5]{index=5}
"$AM_TAP_AWK" < "$log_file" \
  -v test_name="$test_name" \
  -v rc="$rc" \
  -v ignore_exit="$ignore_exit" \
  -v comments="$comments" \
  -v time_begin="$time_begin" \
  -v time_end="$time_end" \
  -v color_tests="$color_tests" \
  -v hard_errors="$hard_errors" \
  'BEGIN{
     plan=0; saw_plan=0; saw_tap=0;
     pass=0; fail=0; skip=0; xfail=0; xpass=0; error=0;
     tc=0;
     desc="";
   }
   function ltrim(s){ sub(/^[ \t\r\n]+/,"",s); return s }
   function rtrim(s){ sub(/[ \t\r\n]+$/,"",s); return s }
   function trim(s){ return rtrim(ltrim(s)) }

   # TAP plan line: 1..N
   $0 ~ /^1\.\.[0-9]+/ {
     split($0,a,".."); plan=a[2]+0; saw_plan=1;
     saw_tap=1;
     if (match($0, /#[ \t]*SKIP /)) {
       skip++
       desc=substr($0, RSTART+RLENGTH)
       printf(":test-result: SKIP %s\n", desc) > "'"$trs_file"'"
     }
   }

   # Test point: ok / not ok
   $0 ~ /^(not[ \t]+)?ok([ \t]+[0-9]+)?([ \t]+-)?/ {
     line=$0
     is_not = (line ~ /^not[ \t]+ok/)
     saw_tap=1;
     # Extract optional number
     n=0
     if (match(line,/^(not[ \t]+)?ok[ \t]+[0-9]+/)) {
       s=substr(line,RSTART,RLENGTH)
       sub(/^(not[ \t]+)?ok[ \t]+/,"",s)
       n=s+0
     } else {
       n=++tc
     }

     # Extract description after "-"
     if (match(line,/[ \t]+-[ \t]+/)) {
       desc=substr(line,RSTART+RLENGTH)
     }
     # Strip directives from description
     sub(/[ \t]*#[ \t]*(SKIP|TODO)\b.*/,"",desc)
     desc=trim(desc)
     if (desc=="") desc=sprintf("test %d", n)

     # Directives
     is_skip = (line ~ /#[ \t]*SKIP\b/)
     is_todo = (line ~ /#[ \t]*TODO\b/)

     if (is_skip) {
       skip++
       printf(":test-result: SKIP %s\n", desc) > "'"$trs_file"'"
     } else if (is_todo) {
       # Minimal TODO mapping: ok+TODO => XFAIL, not ok+TODO => XFAIL
       # (You can refine if you care about XPASS/XFAIL semantics.)
       xfail++
       printf(":test-result: XFAIL %s\n", desc) > "'"$trs_file"'"
     } else if (is_not) {
       fail++
       printf(":test-result: FAIL %s\n", desc) > "'"$trs_file"'"
     } else {
       pass++
       printf(":test-result: PASS %s\n", desc) > "'"$trs_file"'"
     }
     next
   }

   # Comment lines: keep in .log already; optionally treat as metadata? no-op.
   END{
     # Non-zero exit handling mirrors lso-tap-driver: if TAP was emitted,
     # treat the overall result as FAIL; otherwise surface it as ERROR.
     if (ignore_exit != "yes" && rc != 0) {
       if (saw_tap) {
         if (fail==0) {
           fail=1
           desc=sprintf("non-zero exit status (%d)", rc)
           printf(":test-result: FAIL %s\n", desc) > "'"$trs_file"'"
         }
       } else {
         error=1
         printf(":test-result: ERROR %s\n", test_name) > "'"$trs_file"'"
       }
     }

     global="PASS"
     if (error>0) global="ERROR"
     else if (fail>0) global="FAIL"
     else if (pass==0 && skip>0) global="SKIP"

     printf(":global-test-result: %s\n", global) > "'"$trs_file"'"
     printf(":recheck: %s\n", (global=="FAIL"||global=="ERROR") ? "yes" : "no") > "'"$trs_file"'"
     printf(":copy-in-global-log: %s\n", (global=="FAIL"||global=="ERROR"||global=="SKIP") ? "yes" : "no") > "'"$trs_file"'"
     sgr["FAIL"]  = "\033[0;31m"
     sgr["ERROR"] = "\033[1;31m"
     sgr["SKIP"]  = "\033[0;33m"
     sgr["PASS"]  = "\033[0;32m"
     printf("%s%-5s\033[m \033[1m%.03f\033[ms %s\n", color_tests ? sgr[global]: "", global, time_end - time_begin, test_name)
     if (global != "PASS" && desc != "") {
       printf("             > %s\n", desc)
     }
     # Exit code: default to success so the harness can complete even with FAIL.
     # When --enable-hard-errors[=yes] is specified, keep the conventional
     # non-zero exit on FAIL/ERROR to preserve the legacy stop-on-first-failure
     # behaviour for callers that explicitly request it.
     if (hard_errors == "yes" && global ~ /^(FAIL|ERROR)$/) {
       exit 1;
     }
   }'
