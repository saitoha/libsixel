# rights to use, copy, modify, merge, publish, distribute, sublicense, and/or
# sell copies of the Software, and to permit persons to whom the Software is
# furnished to do so, subject to the following conditions:
#
# The above copyright notice and this permission notice shall be included in
# all copies or substantial portions of the Software.
#
# THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR
# IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,
# FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE
# AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER
# LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING
# FROM, OUT OF, OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER
# DEALINGS IN THE SOFTWARE.

set -u

# Prefer configure-time detected test shell. Allow runtime override for
# troubleshooting and platform-specific experiments.
: "${SIXEL_TEST_SHELL:=@SIXEL_TEST_SHELL@}"
: "${SIXEL_TEST_PYTHON:=}"
: "${SIXEL_TEST_RUBY:=}"
: "${SIXEL_TEST_RUBY_GEM_HOME:=}"
: "${SIXEL_TEST_RUBYLIB:=}"
: "${SIXEL_TEST_PERL:=}"
: "${SIXEL_TEST_PERL_CPANM:=}"
: "${SIXEL_TEST_PERL5LIB:=}"
: "${SIXEL_TEST_PERL_LOCAL_LIB_ROOT:=}"
: "${SIXEL_TEST_PERL_MB_OPT:=}"
: "${SIXEL_TEST_PERL_MM_OPT:=}"
: "${SIXEL_TEST_PHP:=}"
: "${SIXEL_TEST_PHP_BINDING_ROOT:=}"
: "${SIXEL_TEST_PHP_LIBDIR:=}"
: "${SIXEL_TEST_PHP_LIBPATH:=}"

test_name=
log_file=
trs_file=
ignore_exit=no
comments=no
test_timeout=
color_tests=
expect_failure=
hard_errors=no
stream_output=auto
stream_fifo=
tee_pid=
run_pid=

cleanup_stream_children() {
  if [ -n "${run_pid}" ]; then
    kill "${run_pid}" >/dev/null 2>&1 || true
    run_pid=
  fi
  if [ -n "${tee_pid}" ]; then
    kill "${tee_pid}" >/dev/null 2>&1 || true
    tee_pid=
  fi
  if [ -n "${stream_fifo}" ]; then
    rm -f "${stream_fifo}" >/dev/null 2>&1 || true
    stream_fifo=
  fi
}

on_interrupt() {
  cleanup_stream_children
  exit 130
}

trap on_interrupt INT TERM HUP

usage() {
  cat <<'EOF' >&2
Usage:
  lso-tap-driver.sh --test-name NAME --log-file PATH.log --trs-file PATH.trs
    [--ignore-exit] [--comments] [--timeout SECONDS]
    [--stream-output {yes|no|auto}]
    [--] TEST-SCRIPT [ARGS...]
EOF
  exit 2
}

# Parse options required by Automake custom test driver protocol.
# (Automake mandates --test-name/--log-file/--trs-file.) :contentReference[oaicite:2]{index=2}
while [ $# -gt 0 ]; do
  case "$1" in
    --help) usage ;;
    --test-name) test_name=${2-}; shift ;;
    --log-file)  log_file=${2-}; shift ;;
    --trs-file)  trs_file=${2-}; shift ;;
    --ignore-exit) ignore_exit=yes ;;
    --comments) comments=yes ;;
    --timeout) test_timeout=${2-}; shift ;;
    --timeout=*) test_timeout=${1#*=} ;;
    --stream-output) stream_output=${2-}; shift ;;
    --stream-output=*) stream_output=${1#*=} ;;
    --color-tests) color_tests=${2-}; shift ;;
    --color-tests=*) color_tests=${1#*=} ;;
    --enable-hard-errors)
      case ${2-} in
        ""|--*) hard_errors=yes ;;
        *) hard_errors=$2; shift ;;
      esac
      ;;
    --enable-hard-errors=*) hard_errors=${1#*=} ;;
    --expect-failure) expect_failure=${2-}; shift ;;
    --expect-failure=*) expect_failure=${1#*=} ;;
    --) shift; break ;;
    -*) echo "lso-tap-driver.sh: invalid option: $1" >&2; usage ;;
    *) break ;;
  esac
  shift
done

[ -n "${test_name}" ] || { echo "lso-tap-driver.sh: missing --test-name" >&2; usage; }
[ -n "${log_file}" ]  || { echo "lso-tap-driver.sh: missing --log-file" >&2; usage; }
[ -n "${trs_file}" ]  || { echo "lso-tap-driver.sh: missing --trs-file" >&2; usage; }
[ $# -ge 1 ] || { echo "lso-tap-driver.sh: missing TEST-SCRIPT" >&2; usage; }

if [ "$stream_output" = auto ] && [ -n "${LSO_TAP_STREAM_LOG-}" ]; then
  stream_output=${LSO_TAP_STREAM_LOG}
fi

case "$stream_output" in
  auto)
    case "$test_name" in
      staticcheck-*) stream_output=yes ;;
      *) stream_output=no ;;
    esac
    ;;
  yes|no) ;;
  *)
    echo "lso-tap-driver.sh: invalid --stream-output value: $stream_output" >&2
    usage
    ;;
esac

: "${TOP_SRCDIR:=@top_srcdir@}"
: "${AM_TAP_AWK:=awk}"
: "${LSO_TAP_TIMER_BIN:=@top_builddir@/tools/lso-timer@EXEEXT@}"
: "${LSO_TAP_TIMER_SRC:=@top_srcdir@/tools/lso-timer@EXEEXT@}"
: "${LSO_TAP_TIMER_BUILD:=@top_builddir@/tools/lso-timer@EXEEXT@}"
: "${LSO_TAP_TIMEOUT_BIN:=@top_builddir@/tools/lso-timeout@EXEEXT@}"
: "${LSO_TAP_TIMEOUT_SRC:=@top_srcdir@/tools/lso-timeout@EXEEXT@}"
: "${LSO_TAP_TIMEOUT_BUILD:=@top_builddir@/tools/lso-timeout@EXEEXT@}"
timeout_budget=${test_timeout:-90}
kill_delay=10

test_script=$1
test_name_base=${test_name##*[/\\]}
test_dir=${test_script%[/\\]*}
if [ "${test_dir}" = "${test_script}" ]; then
  test_dir=.
fi
category_name=${test_dir#*tests/}
artifact_root="${TOP_BUILDDIR}/tests/_artifacts"
ARTIFACT_LOCAL_DIR="${artifact_root}/${category_name}/${test_name_base}"
export test_dir
export category_name
export ARTIFACT_LOCAL_DIR

# Keep runtime library lookup setup in the test driver so each test process
# gets a fresh, direct assignment without relying on recursive make exports.
runtime_var=${RUNTIME_SHLIBPATH_VAR-}
runtime_sep=${RUNTIME_SHLIBPATH_SEP-:}
runtime_extra=${SIXEL_TEST_ADDITIOANL_PATH-}
runtime_libdir=${LIBSIXEL_LIBDIR-}
runtime_inject_active=no
LSO_RUNTIME_SHLIBPATH_VALUE=
if [ -z "$runtime_libdir" ]; then
  runtime_libdir="${TOP_BUILDDIR}/src/.libs"
fi
if [ "${SIXEL_SHLIBPATH_OVERRIDES_RUNPATH-}" = "yes" ] && [ -n "$runtime_var" ]; then
  runtime_current=$(printenv "$runtime_var" 2>/dev/null || printf '')
  runtime_value="$runtime_libdir"
  if [ -n "$runtime_extra" ]; then
    runtime_value="${runtime_value}${runtime_sep}${runtime_extra}"
  fi
  if [ -n "$runtime_current" ]; then
    runtime_value="${runtime_value}${runtime_sep}${runtime_current}"
  fi
  LSO_RUNTIME_SHLIBPATH_VALUE=$runtime_value
  runtime_inject_active=yes
  export LSO_RUNTIME_SHLIBPATH_VALUE
  export "$runtime_var=$runtime_value"
fi

timestamp_millis() {
  if [ -x "$LSO_TAP_TIMER_BIN" ]; then
    ${SIXEL_RUNTIME-} "$LSO_TAP_TIMER_BIN" && return
  fi

  if [ -x "$LSO_TAP_TIMER_BUILD" ]; then
    ${SIXEL_RUNTIME-} "$LSO_TAP_TIMER_BUILD" && return
  fi

  if [ -x "$LSO_TAP_TIMER_SRC" ]; then
    ${SIXEL_RUNTIME-} "$LSO_TAP_TIMER_SRC" && return
  fi

  date +%s
}

select_timeout_bin() {
  if command -v timeout >/dev/null 2>&1; then
    echo "timeout"
    return
  fi
  if command -v gtimeout >/dev/null 2>&1; then
    echo "gtimeout"
    return
  fi
  if [ -n "${SIXEL_RUNTIME-}" ]; then
    echo ""
    return
  fi
  if [ -x "$LSO_TAP_TIMEOUT_BIN" ]; then
    echo "$LSO_TAP_TIMEOUT_BIN"
    return
  fi
  if [ -x "$LSO_TAP_TIMEOUT_BUILD" ]; then
    echo "$LSO_TAP_TIMEOUT_BUILD"
    return
  fi
  if [ -x "$LSO_TAP_TIMEOUT_SRC" ]; then
    echo "$LSO_TAP_TIMEOUT_SRC"
    return
  fi

  echo ""
}

run_with_helper() {
  helper=$1
  shift
  ${helper} -k "${kill_delay}s" "${timeout_budget}s" "$@"
  status=$?
  if [ "$status" -eq 124 ] || [ "$status" -eq 137 ]; then
    echo "Bail out! timeout after ${timeout_budget}s" >&2
  fi
  return "$status"
}

run_with_timeout() {
  helper_bin=$(select_timeout_bin)
  test_path=$1
  shift

  case "$test_path" in
    *.py)
      run_desc="python ${test_path}"
      if [ -n "${SIXEL_TEST_PYTHON}" ] && [ -x "${SIXEL_TEST_PYTHON}" ]; then
        set -- "$SIXEL_TEST_PYTHON" "$test_path" "$@"
      else
        printf '%s\n' '1..0 # SKIP python test interpreter is unavailable' >"$log_file"
        cat >"$trs_file" <<'EOF'
:test-result: SKIP
:global-test-result: SKIP
:recheck: yes
:copy-in-global-log: no
EOF
        return 0
      fi
      ;;
    *.rb)
      run_desc="ruby ${test_path}"
      if [ -n "${SIXEL_TEST_RUBY}" ] && [ -x "${SIXEL_TEST_RUBY}" ]; then
        if [ -n "${SIXEL_TEST_RUBY_GEM_HOME}" ]; then
          if [ -n "${SIXEL_TEST_RUBYLIB}" ]; then
            if [ -n "${RUBYLIB:-}" ]; then
              RUBYLIB="${SIXEL_TEST_RUBYLIB}:${RUBYLIB}" \
                export RUBYLIB
            else
              RUBYLIB="${SIXEL_TEST_RUBYLIB}" \
                export RUBYLIB
            fi
          fi
          GEM_HOME="${SIXEL_TEST_RUBY_GEM_HOME}" \
          GEM_PATH="${SIXEL_TEST_RUBY_GEM_HOME}" \
            export GEM_HOME GEM_PATH
        else
          # Fallback for source-tree Ruby tests when no bundled gem test
          # environment is available.
          ruby_lib_path="${TOP_BUILDDIR}/ruby/lib:${TOP_SRCDIR}/ruby/lib"
          if [ -n "${RUBYLIB:-}" ]; then
            RUBYLIB="${ruby_lib_path}:${RUBYLIB}" \
              export RUBYLIB
          else
            RUBYLIB="${ruby_lib_path}" \
              export RUBYLIB
          fi
        fi
        set -- "$SIXEL_TEST_RUBY" "$test_path" "$@"
      else
        printf '%s\n' '1..0 # SKIP ruby test interpreter is unavailable' >"$log_file"
        cat >"$trs_file" <<'EOF'
:test-result: SKIP
:global-test-result: SKIP
:recheck: yes
:copy-in-global-log: no
EOF
        return 0
      fi
      ;;
    *.pl)
      run_desc="perl ${test_path}"
      if [ -n "${SIXEL_TEST_PERL}" ] && [ -x "${SIXEL_TEST_PERL}" ]; then
        if [ -n "${SIXEL_TEST_PERL5LIB}" ]; then
          if [ -n "${PERL5LIB:-}" ]; then
            PERL5LIB="${SIXEL_TEST_PERL5LIB}:${PERL5LIB}" \
              export PERL5LIB
          else
            PERL5LIB="${SIXEL_TEST_PERL5LIB}" \
              export PERL5LIB
          fi
        fi
        if [ -n "${SIXEL_TEST_PERL_LOCAL_LIB_ROOT}" ]; then
          PERL_LOCAL_LIB_ROOT="${SIXEL_TEST_PERL_LOCAL_LIB_ROOT}" \
            export PERL_LOCAL_LIB_ROOT
        fi
        if [ -n "${SIXEL_TEST_PERL_MB_OPT}" ]; then
          PERL_MB_OPT="${SIXEL_TEST_PERL_MB_OPT}" \
            export PERL_MB_OPT
        fi
        if [ -n "${SIXEL_TEST_PERL_MM_OPT}" ]; then
          PERL_MM_OPT="${SIXEL_TEST_PERL_MM_OPT}" \
            export PERL_MM_OPT
        fi
        set -- "$SIXEL_TEST_PERL" "$test_path" "$@"
      else
        printf '%s\n' '1..0 # SKIP perl test interpreter is unavailable' >"$log_file"
        cat >"$trs_file" <<'EOF'
:test-result: SKIP
:global-test-result: SKIP
:recheck: yes
:copy-in-global-log: no
EOF
        return 0
      fi
      ;;
    *.php)
      run_desc="php ${test_path}"
      if [ -n "${SIXEL_TEST_PHP}" ] && [ -x "${SIXEL_TEST_PHP}" ]; then
        if [ -n "${SIXEL_TEST_PHP_BINDING_ROOT}" ]; then
          SIXEL_TEST_PHP_BINDING_ROOT="${SIXEL_TEST_PHP_BINDING_ROOT}" \
            export SIXEL_TEST_PHP_BINDING_ROOT
        fi
        if [ -n "${SIXEL_TEST_PHP_LIBDIR}" ]; then
          LIBSIXEL_LIBDIR="${SIXEL_TEST_PHP_LIBDIR}" \
            export LIBSIXEL_LIBDIR
        fi
        if [ -n "${SIXEL_TEST_PHP_LIBPATH}" ]; then
          LIBSIXEL_LIBPATH="${SIXEL_TEST_PHP_LIBPATH}" \
            export LIBSIXEL_LIBPATH
        fi
        set -- "$SIXEL_TEST_PHP" "$test_path" "$@"
      else
        printf '%s\n' '1..0 # SKIP php test interpreter is unavailable' >"$log_file"
        cat >"$trs_file" <<'EOF'
:test-result: SKIP
:global-test-result: SKIP
:recheck: yes
:copy-in-global-log: no
EOF
        return 0
      fi
      ;;
    *)
      run_desc="shell ${test_path}"
      if [ "$runtime_inject_active" = "yes" ] && [ -n "$runtime_var" ]; then
        set -- "$SIXEL_TEST_SHELL" -c \
          'runtime_var=$1; runtime_value=$2; script=$3; shift 3; export "$runtime_var=$runtime_value"; . "$script" "$@"' \
          "$test_path" "$runtime_var" "$LSO_RUNTIME_SHLIBPATH_VALUE" "$test_path" "$@"
      else
        set -- "$SIXEL_TEST_SHELL" "$test_path" "$@"
      fi
      ;;
  esac

  echo "# lso-tap-driver: ${run_desc}"

  if [ -n "$helper_bin" ]; then
    run_with_helper "$helper_bin" "$@"
    return $?
  fi

  "$@"
  return $?
}

run_and_capture() {
  if [ "$stream_output" = "yes" ]; then
    stream_fifo=$(mktemp "${TMPDIR:-/tmp}/libsixel-tap-stream-XXXXXX")
    rm -f "$stream_fifo"
    if ! mkfifo "$stream_fifo"; then
      run_with_timeout "$@" >"$log_file" 2>&1
      return $?
    fi

    tee "$log_file" <"$stream_fifo" &
    tee_pid=$!
    run_with_timeout "$@" >"$stream_fifo" 2>&1 &
    run_pid=$!

    wait "$run_pid"
    capture_status=$?
    run_pid=
    rm -f "$stream_fifo"
    stream_fifo=
    wait "$tee_pid" >/dev/null 2>&1 || true
    tee_pid=
    return "$capture_status"
  fi

  run_with_timeout "$@" >"$log_file" 2>&1
  return $?
}

# Run the test script, capture all output in .log (format free). :contentReference[oaicite:3]{index=3}
# Staticcheck targets stream output to console while preserving .log files.
if [ "$stream_output" = "yes" ]; then
    # Streaming output cannot be wrapped in command substitution because that
    # would swallow progress lines; use timestamp helper instead.
    time_begin=$(timestamp_millis)
    run_and_capture "$@"
    rc=$?
    time_end=$(timestamp_millis)
elif test "$(command -v time)" = time; then
    # use builtin time
    time_begin=0.000
    time_end=$( TIMEFORMAT='%R'; { time run_and_capture "$@"; } 2>&1 )
    rc=$?
else
    time_begin=$(timestamp_millis)
    run_and_capture "$@"
    rc=$?
    time_end=$(timestamp_millis)
fi

if test "${reduce_fork-}" != yes; then
# Generate .trs (reStructuredText fields), at minimum :test-result: fields. :contentReference[oaicite:4]{index=4}
# Also write :global-test-result:, :recheck:, :copy-in-global-log: for convenience
# (Automake recognizes these fields). :contentReference[oaicite:5]{index=5}
LC_ALL=C "$AM_TAP_AWK" < "$log_file" \
  -v test_name="$test_name" \
  -v rc="$rc" \
  -v ignore_exit="$ignore_exit" \
  -v comments="$comments" \
  -v time_begin="$time_begin" \
  -v time_end="$time_end" \
  -v color_tests="$color_tests" \
  -v hard_errors="$hard_errors" \
  'BEGIN{
     plan=0; saw_plan=0; saw_tap=0;
     pass=0; fail=0; skip=0; xfail=0; xpass=0; error=0;
     tc=0;
     desc="";
   }
   function ltrim(s){ sub(/^[ \t\r\n]+/,"",s); return s }
   function rtrim(s){ sub(/[ \t\r\n]+$/,"",s); return s }
   function trim(s){ return rtrim(ltrim(s)) }

   # TAP plan line: 1..N
   $0 ~ /^1\.\.[0-9]+/ {
     split($0,a,".."); plan=a[2]+0; saw_plan=1;
     saw_tap=1;
     if (match($0, /#[ \t]*SKIP /)) {
       skip++
       desc=substr($0, RSTART+RLENGTH)
       printf(":test-result: SKIP %s\n", desc) > "'"$trs_file"'"
     }
   }

   # Test point: ok / not ok
   # Require a boundary after "ok" so fragments like `ok"` / `not ok"`
   # from verbose shell traces are not parsed as TAP records.
   $0 ~ /^(not[ \t]+)?ok([ \t]|$)/ {
     line=$0
     is_not = (line ~ /^not[ \t]+ok([ \t]|$)/)
     saw_tap=1;
     # Extract optional number
     n=0
     if (match(line,/^(not[ \t]+)?ok[ \t]+[0-9]+/)) {
       s=substr(line,RSTART,RLENGTH)
       sub(/^(not[ \t]+)?ok[ \t]+/,"",s)
       n=s+0
     } else {
       n=++tc
     }

     # Extract description after "-"
     if (match(line,/[ \t]+-[ \t]+/)) {
       desc=substr(line,RSTART+RLENGTH)
     }
     # Strip directives from description
     sub(/[ \t]*#[ \t]*(SKIP|TODO)\b.*/,"",desc)
     desc=trim(desc)
     if (desc=="") desc=sprintf("test %d", n)

     # Directives
     is_skip = (line ~ /#[ \t]*SKIP\b/)
     is_todo = (line ~ /#[ \t]*TODO\b/)

     if (is_skip) {
       skip++
       printf(":test-result: SKIP %s\n", desc) > "'"$trs_file"'"
     } else if (is_todo) {
       # Minimal TODO mapping: ok+TODO => XFAIL, not ok+TODO => XFAIL
       # (You can refine if you care about XPASS/XFAIL semantics.)
       xfail++
       printf(":test-result: XFAIL %s\n", desc) > "'"$trs_file"'"
     } else if (is_not) {
       fail++
       printf(":test-result: FAIL %s\n", desc) > "'"$trs_file"'"
     } else {
       pass++
       printf(":test-result: PASS %s\n", desc) > "'"$trs_file"'"
     }
     next
   }

   # Comment lines: keep in .log already; optionally treat as metadata? no-op.
   END{
     # Non-zero exit handling mirrors lso-tap-driver: if TAP was emitted,
     # treat the overall result as FAIL; otherwise surface it as ERROR.
     if (ignore_exit != "yes" && rc != 0) {
       if (saw_tap) {
         if (fail==0) {
           fail=1
           desc=sprintf("non-zero exit status (%d)", rc)
           printf(":test-result: FAIL %s\n", desc) > "'"$trs_file"'"
         }
       } else {
         error=1
         printf(":test-result: ERROR %s\n", test_name) > "'"$trs_file"'"
       }
     }

     global="PASS"
     if (error>0) global="ERROR"
     else if (fail>0) global="FAIL"
     else if (pass==0 && skip>0) global="SKIP"

     printf(":global-test-result: %s\n", global) > "'"$trs_file"'"
     printf(":recheck: %s\n", (global=="FAIL"||global=="ERROR") ? "yes" : "no") > "'"$trs_file"'"
     printf(":copy-in-global-log: %s\n", (global=="FAIL"||global=="ERROR"||global=="SKIP") ? "yes" : "no") > "'"$trs_file"'"
     sgr["FAIL"]  = "\033[0;31m"
     sgr["ERROR"] = "\033[1;31m"
     sgr["SKIP"]  = "\033[0;33m"
     sgr["PASS"]  = "\033[0;32m"
     printf("%s%-5s\033[m \033[1m%.03f\033[ms %s\n", color_tests ? sgr[global]: "", global, time_end - time_begin, test_name)
     if (global != "PASS" && desc != "") {
       printf("             > %s\n", desc)
     }
     # Exit code: default to success so the harness can complete even with FAIL.
     # When --enable-hard-errors[=yes] is specified, keep the conventional
     # non-zero exit on FAIL/ERROR to preserve the legacy stop-on-first-failure
     # behaviour for callers that explicitly request it.
     if (hard_errors == "yes" && global ~ /^(FAIL|ERROR)$/) {
       exit 1;
     }
   }'

else

# - Plan:        "1..N"
# - Pass:        "ok <case> - <description>"
# - Fail:        "not ok <case> - <description>"
# - Skip(all):   "1..0 # SKIP <reason>"
# - Skip:        "ok <case> # SKIP <reason>"
{
    rc=0
    saw_plan=0
    saw_tap=0
    pass=0
    skip=0
    error=0
    fail=0
    is_not=0
    shutdown=0
    while read line; do
        read col1 col2 col3 col4 <<__line__
${line}
__line__
        case "$col1" in
            1..*)
                saw_plan=1
                saw_tap=1
                test "$col2" = '#' && test "$col3" = SKIP && {
                    desc="${col4}"
                    echo ":test-result: SKIP $desc" >&2
                    break
                }
                plan="${col1%1..}"
                ;;
            ok)
                saw_tap=1
                is_not=0
                n="${col2}"
                test "$col3" = '#' && test "$col4" = SKIP && {
                    skip=$((skip+1))
                    desc="${line#*SKIP}"
                    echo ":test-result: SKIP $desc" >&2
                }
                echo ":test-result: PASS ${line#*-}" >&2
                ;;
            not)
                test "$col2" = ok || continue
                saw_tap=1
                is_not=1
                n="${col3}"
                echo ":test-result: FAIL ${line#*-}" >&2
                ;;
        esac
    done < "$log_file"
    
    test ! "$ignore_exit" = "yes" && test "$rc" -gt 0 && {
        case "${saw_tap}" in
        0)
            error=1
            echo ":test-result: ERROR $test_name" >&2
            ;;
        *)
            case "${fail}" in
            0)
                fail=1
                desc="non-zero exit status ($rc)"
                echo ":test-result: FAIL $desc" >&2
                ;;
            esac
        esac 
    }
    
    e=$(printf "\033")
    global="PASS"
    recheck=no
    copy=no
    sgr="$e[0;32m"
    test "$error" -gt 0 && {
        global="ERROR"
        recheck=yes
        copy=yes
        sgr="$e[1;31m"
        test "$hard_errors" = "yes" && shutdown=1
    }
    test "$fail" -gt 0 && {
        global="FAIL"
        recheck=yes
        copy=yes
        sgr="$e[0;31m"
        test "$hard_errors" = "yes" && shutdown=1
    }
    test "$pass" -eq 0 && test "$skip" -gt 0 && {
        global="SKIP"
        copy=yes
        sgr="$e[0;33m"
    }
    test "$color_tests" = yes || {
        sgr=
    }
    time_begin_scaled=$(printf %d "${time_begin%.*}${time_begin#*.}")
    time_end_scaled=$(printf %d "${time_end%.*}${time_end#*.}")
    duration_ms=$((${time_end_scaled} - ${time_begin_scaled}))
    duration=$(printf "%d.%03d" $((duration_ms/1000)) $((duration_ms%1000)))
    {
        echo ":global-test-result: $global"
        echo ":recheck: $recheck"
        echo ":copy-in-global-log: $copy"
    } >&2
    printf "%s%-5s\033[m \033[1m%.03f\033[ms %s\n" "$sgr" "$global" "$duration" "$test_name"
    test "$global" != "PASS" && "$desc" != "" && {
      echo "             > $desc"
    }
} 2> "$trs_file"
test "$shutdown" -eq 0 || rc=1
fi
