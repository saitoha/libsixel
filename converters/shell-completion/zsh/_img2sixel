_quantizemodel() {
  local current base segment key prefix

  current=${words[CURRENT]}
  if [[ ${current} == *:* ]]; then
    base=${current%%:*}
    segment=${current##*:}
    if [[ ${base} == auto || ${base} == auto* || \
          ${base} == heckbert || ${base} == heckbert* ]]; then
      if [[ ${segment} == *=* ]]; then
        key=${segment%%=*}
        prefix=${current%${segment}}
        if [[ ${key} == merge || ${key} == g ]]; then
          compadd -- "${prefix}${key}=auto" \
                     "${prefix}${key}=none" \
                     "${prefix}${key}=ward"
          return 0
        elif [[ ${key} == animation_mode ]]; then
          compadd -- "${prefix}${key}=0" \
                     "${prefix}${key}=1"
          return 0
        elif [[ ${key} == scene_cut_threshold ]]; then
          compadd -- "${prefix}${key}=0.15" \
                     "${prefix}${key}=0.20" \
                     "${prefix}${key}=0.30"
          return 0
        elif [[ ${key} == merge_oversplit || ${key} == o ]]; then
          compadd -- "${prefix}${key}=1.2" \
                     "${prefix}${key}=1.5" \
                     "${prefix}${key}=1.8" \
                     "${prefix}${key}=2.0"
          return 0
        elif [[ ${key} == merge_lloyd || ${key} == l ]]; then
          compadd -- "${prefix}${key}=0" \
                     "${prefix}${key}=1" \
                     "${prefix}${key}=3" \
                     "${prefix}${key}=5" \
                     "${prefix}${key}=8"
          return 0
        fi
      else
        prefix=${current%${segment}}
        compadd -- "${prefix}animation_mode=" \
                   "${prefix}scene_cut_threshold=" \
                   "${prefix}g=" \
                   "${prefix}merge=" \
                   "${prefix}o=" \
                   "${prefix}merge_oversplit=" \
                   "${prefix}l=" \
                   "${prefix}merge_lloyd="
        return 0
      fi
    elif [[ ${base} == k || ${base} == kmeans* ]]; then
      if [[ ${segment} == *=* ]]; then
        key=${segment%%=*}
        prefix=${current%${segment}}
        if [[ ${key} == i || ${key} == inittype ]]; then
          compadd -- "${prefix}${key}=auto" \
                     "${prefix}${key}=none" \
                     "${prefix}${key}=pca"
          return 0
        elif [[ ${key} == b || ${key} == binning ]]; then
          compadd -- "${prefix}${key}=auto" \
                     "${prefix}${key}=none" \
                     "${prefix}${key}=hard" \
                     "${prefix}${key}=soft"
          return 0
        elif [[ ${key} == m || ${key} == mapping ]]; then
          compadd -- "${prefix}${key}=uniform" \
                     "${prefix}${key}=srgb"
          return 0
        elif [[ ${key} == d || ${key} == softdist ]]; then
          compadd -- "${prefix}${key}=trilinear"
          return 0
        elif [[ ${key} == n || ${key} == binbits ]]; then
          compadd -- "${prefix}${key}=4" \
                     "${prefix}${key}=5" \
                     "${prefix}${key}=6" \
                     "${prefix}${key}=7" \
                     "${prefix}${key}=8"
          return 0
        elif [[ ${key} == r || ${key} == autoratio ]]; then
          compadd -- "${prefix}${key}=8" \
                     "${prefix}${key}=16" \
                     "${prefix}${key}=32" \
                     "${prefix}${key}=64"
          return 0
        elif [[ ${key} == f || ${key} == feedback ]]; then
          compadd -- "${prefix}${key}=off" \
                     "${prefix}${key}=on"
          return 0
        elif [[ ${key} == s || ${key} == seed ]]; then
          compadd -- "${prefix}${key}=1" \
                     "${prefix}${key}=7" \
                     "${prefix}${key}=42" \
                     "${prefix}${key}=256"
          return 0
        elif [[ ${key} == restarts ]]; then
          compadd -- "${prefix}${key}=1" \
                     "${prefix}${key}=2" \
                     "${prefix}${key}=4" \
                     "${prefix}${key}=8" \
                     "${prefix}${key}=16"
          return 0
        elif [[ ${key} == iter || ${key} == iter_max ]]; then
