          return 0
        elif [[ ${key} == merge_lloyd || ${key} == l ]]; then
          compadd -- "${prefix}${key}=0" \
                     "${prefix}${key}=1" \
                     "${prefix}${key}=3" \
                     "${prefix}${key}=5" \
                     "${prefix}${key}=8"
          return 0
        fi
      else
        prefix=${current%${segment}}
        compadd -- "${prefix}a=" "${prefix}algo=" \
                   "${prefix}s=" "${prefix}seed=" \
                   "${prefix}restarts=" \
                   "${prefix}iter=" \
                   "${prefix}histbits=" \
                   "${prefix}point_budget=" \
                   "${prefix}prune_mass=" \
                   "${prefix}animation_mode=" \
                   "${prefix}scene_cut_threshold=" \
                   "${prefix}g=" \
                   "${prefix}merge=" \
                   "${prefix}o=" \
                   "${prefix}merge_oversplit=" \
                   "${prefix}l=" \
                   "${prefix}merge_lloyd="
        return 0
      fi
    fi
  fi

  _values \
    'MODEL' \
    'auto[select solver automatically]' \
    'heckbert[Heckbert median-cut solver]' \
    'kmeans[k-means palette solver]' \
    'medoids[k-medoids palette solver]' \
    'center[discrete k-center palette solver]'
}


_completiontarget() {
  _values \
    'TARGET' \
    'all[manage both bash and zsh completions]' \
    'bash[operate on bash completions only]' \
    'zsh[operate on zsh completions only]'
}

_threadcount() {
  _values \
    'THREADS' \
    'auto[match the hardware thread count]'
}

_precisionmode() {
  _values \
    'PRECISIONMODE' \
    'auto[defer to SIXEL_FLOAT32_DITHER or the 8-bit default]' \
    '8bit[force the legacy integer pipeline]' \
    'float32[opt into the experimental high-precision pipeline]'
}

# Keep the following option order synchronized with `img2sixel -H`.
_arguments -S -s -A "-*" -S \
  {-o,--outfile}'[specify output file (default: stdout)]':files:_files \
  {-=,--threads=}'[override encoder thread count (integer or auto)]':threadcount:_threadcount \
  {-.,--precision=}'[control quantization precision]':precisionmode:_precisionmode \
  {-7,--7bit-mode}'[generate a sixel image for 7bit terminals (default)]' \
  {-8,--8bit-mode}'[generate a sixel image for 8bit terminals]' \
  {-R,--gri-limit}'[limit arguments of DECGRI(!) to 255]' \
  {-6,--6reversible}'[snap the palette to SIXEL-reversible tones]' \
  {-p,--colors=}'[specify number of colors to reduce the image to]' \
  {-Q,--quantize-model=}'[choose palette solver]':quantizemodel:_quantizemodel \
  {-m,--mapfile=}'[transform image colors using a map image or ACT/PAL/GPL palette; TYPE:PATH prefixes (TYPE:- for stdin) allowed]':files:_files \
  {-M,--mapfile-output=}'[export the computed palette; TYPE:PATH (TYPE:- for stdout) or .act/.pal/.gpl extensions choose the format]':files:_files \
  {-e,--monochrome}'[output monochrome sixel image]' \
  {-k,--insecure}'[allow to connect to SSL sites without certs]' \
  {-i,--invert}'[assume the terminal background color is white]' \
  {-I,--high-color}'[output 15bpp sixel image]' \
  {-u,--use-macro}'[use DECDMAC and DECINVM for GIF animation]' \
  {-n,--macro-number}'[specify a number argument for DECDMAC]' \
  {-C,--complexion-score=}'[specify a score value for complexion correction]' \
  {-g,--ignore-delay}'[render GIF animation without delay]' \
  {-S,--static}'[render animated GIF as a static image]' \
  {-d,--diffusion=}'[choose diffusion method which used with -p option]':diffusiontype:_diffusiontype \
  {-f,--find-largest=}'[method for finding the largest dimension in median-cut]':findtype:_findtype \
  {-s,--select-color=}'[method for selecting color from median-cut boxes]':selecttype:_selecttype \
  {-c,--crop=}'[crop image to specified geometory(%dx%d+%d+%d)]' \
  {-w,--width=}'[resize image width (auto, numeric, percent, pixel, terminal cell)]' \
  {-h,--height=}'[resize image height (auto, numeric, percent, pixel, terminal cell)]' \
  {-r,--resampling=}'[choose resampling filter used with -w or -h option]':resamplingtype:_resamplingtype \
  {-q,--quality=}'[select quality of color quanlization]':qualitytype:_qualitytype \
  {-~,--lookup-policy=}'[choose histogram lookup width and backend]':lookuppolicy:_lookuppolicy \
  {-l,--loop-control=}'[select loop control mode of GIF animation]':looptype:_looptype \
  {-T,--start-frame=}'[set animation start frame index for loaders]' \
  {-t,--palette-type=}'[select palette color space type]':palettetype:_palettetype \
  {-b,--builtin-palette=}'[select built-in palette type]':builtinpalette:_builtinpalette \
  {-E,--encode-policy=}'[select encoding policy]':encodepolicy:_encodepolicy \
  {-B,--bgcolor=}'[select background color]' \
  {-P,--penetrate}'[penetrate GNU Screen using DCS pass-through sequence]' \
  {-D,--pipe-mode}'[read source images from stdin continuously]' \
  {-v,--verbose}'[show debugging information]' \
  {-L,--loaders=}'[override loader priority order]':loaders:_loaders \
  {-#,--cms-engine=}'[set default loader CMS backend]':cmsengine:_cmsengine \
  {-@,--drcs}'[emit DRCS tiles via MMV:CHARSET:PATH (defaults 2:1:, "-" keeps stdout)]' \
  {-O,--ormode}'[output ormode sixel image]' \
  {-X,--clustering-colorspace=}'[select palette clustering color space]':colorspace:_clusteringcolorspace \
  {-W,--working-colorspace=}'[select internal working color space]':workingcolorspace:_workingcolorspace \
  {-U,--output-colorspace=}'[select output color space]':outputcolorspace:_outputcolorspace \
  {-1,--show-completion=}'[print shell completion script]':target:_completiontarget \
  {-2,--install-completion=}'[install shell completion script]':target:_completiontarget \
  {-3,--uninstall-completion=}'[remove installed shell completion script]':target:_completiontarget \
  {-%,--env=}'[set process environment variable (KEY=VALUE)]' \
  {-V,--version}'[show version and license information]' \
  {-H,--help}'[show help]' \
  '*:files:_files' \
  && return 0

return 1

