.PRECIOUS: Makefile


# +--------------------------------------------------------------+
# | Embedded completion header generation pipeline (ASCII view). |
# +--------------------------------------------------------------+
# bash/img2sixel ----\
#                      >--[gen_completion_embed.awk]--> completion_embed.h
# zsh/_img2sixel  ----/

# Keep this recipe tab-indented; GNU make requires tabs for commands.
completion_embed.h: \
	$(srcdir)/shell-completion/bash/img2sixel \
	$(srcdir)/shell-completion/zsh/_img2sixel \
	$(top_srcdir)/tools/gen_completion_embed.awk
	$(AM_V_GEN)tmp="$@.tmp"; \
	$(AWK) -f $(top_srcdir)/tools/gen_completion_embed.awk \
	       $(srcdir)/shell-completion/bash/img2sixel \
	       $(srcdir)/shell-completion/zsh/_img2sixel > "$$tmp" && \
	mv "$$tmp" "$@" || { rm -f "$$tmp"; exit 1; }
# Ensure completion_utils never compiles before the generated header exists.
@WANT_AMALGAMATED_TOOLS_FALSE@@WANT_IMG2SIXEL_TRUE@img2sixel-completion_utils.$(OBJEXT): completion_embed.h

@WITH_SHEBANG_FILE_TRUE@$(SIXEL_SHEBANG_STAMP): $(SIXEL_SHEBANG_TARGETS)
@WITH_SHEBANG_FILE_TRUE@	@if test -n "$(SIXEL_SHEBANG_TARGETS)"; then \
@WITH_SHEBANG_FILE_TRUE@		$(SIXEL_SHEBANG_HELPER) "$(SIXEL_SHEBANG_FILE)" \
@WITH_SHEBANG_FILE_TRUE@			$(SIXEL_SHEBANG_TARGETS); \
@WITH_SHEBANG_FILE_TRUE@	fi
@WITH_SHEBANG_FILE_TRUE@	@touch $@

@WITH_SHEBANG_FILE_TRUE@all-local: $(SIXEL_SHEBANG_STAMP)

# Keep this recipe tab-indented; GNU make requires tabs for commands.
@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@install-exec-hook:
@WANT_IMG2SIXEL_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@	$(INSTALL_SCRIPT) "$(builddir)/img2sixel-node-launcher" \
@WANT_IMG2SIXEL_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@		"$(DESTDIR)$(bindir)/img2sixel"
@WANT_IMG2SIXEL_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@	@if test -f "img2sixel.wasm"; then \
@WANT_IMG2SIXEL_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@		$(INSTALL_DATA) "img2sixel.wasm" \
@WANT_IMG2SIXEL_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@			"$(DESTDIR)$(pkglibexecdir)/img2sixel.wasm"; \
@WANT_IMG2SIXEL_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@	fi
@WANT_SIXEL2PNG_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@	$(INSTALL_SCRIPT) "$(builddir)/sixel2png-node-launcher" \
@WANT_SIXEL2PNG_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@		"$(DESTDIR)$(bindir)/sixel2png"
@WANT_SIXEL2PNG_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@	@if test -f "sixel2png.wasm"; then \
@WANT_SIXEL2PNG_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@		$(INSTALL_DATA) "sixel2png.wasm" \
@WANT_SIXEL2PNG_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@			"$(DESTDIR)$(pkglibexecdir)/sixel2png.wasm"; \
@WANT_SIXEL2PNG_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@	fi

# Keep this recipe tab-indented; GNU make requires tabs for commands.
@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@uninstall-hook:
@WANT_IMG2SIXEL_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@	rm -f "$(DESTDIR)$(bindir)/img2sixel"
@WANT_IMG2SIXEL_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@	rm -f "$(DESTDIR)$(pkglibexecdir)/img2sixel.wasm"
@WANT_SIXEL2PNG_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@	rm -f "$(DESTDIR)$(bindir)/sixel2png"
@WANT_SIXEL2PNG_TRUE@@WITH_EMSCRIPTEN_SPLIT_MODE_TRUE@	rm -f "$(DESTDIR)$(pkglibexecdir)/sixel2png.wasm"

.PHONY: prelink-objs
prelink-objs: $(BUILT_SOURCES) $(PRELINK_OBJECTS)

# Tell versions [3.59,3.63) of GNU make to not export all variables.
# Otherwise a system limit (for SysV at least) may be exceeded.
.NOEXPORT:

# Tell GNU make to disable its built-in pattern rules.
%:: %,v
%:: RCS/%,v
%:: RCS/%
%:: s.%
%:: SCCS/s.%
