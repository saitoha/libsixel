<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="image/sixel">
    <comment>DEC SIXEL image</comment>
    <magic priority="60">
      <match type="string" offset="0" value="\x1bPq"/>
      <match type="string" offset="0" value="\x1bP"/>
    </magic>
    <glob pattern="*.six"/>
    <glob pattern="*.sixel"/>
  </mime-type>
  <mime-type type="image/x-sixel">
    <alias type="image/sixel"/>
    <glob pattern="*.six"/>
    <glob pattern="*.sixel"/>
  </mime-type>
</mime-info>
