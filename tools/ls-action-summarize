#!/usr/bin/env python3
"""Summarize GitHub Actions run results with optional failed-job details."""

from __future__ import annotations

import argparse
import concurrent.futures
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
from collections import Counter, defaultdict
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, Iterable, List, Optional


ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")
FAILED_TEST_RESULTS = {
    "ERROR",
    "FAIL",
    "INTERRUPT",
    "TIMEOUT",
    "TIMED_OUT",
    "UNEXPECTEDPASS",
    "XPASS",
}


def run_cmd(cmd: list[str], cwd: str | None = None, text: bool = True) -> str:
    return subprocess.check_output(cmd, cwd=cwd, text=text, stderr=subprocess.STDOUT).strip()


def parse_iso8601(ts: Optional[str]) -> Optional[datetime]:
    if not ts:
        return None
    return datetime.fromisoformat(ts.replace("Z", "+00:00"))


def format_time_delta(start: Optional[datetime], end: Optional[datetime]) -> str:
    if not start or not end:
        return "n/a"
    seconds = max(0, int((end - start).total_seconds()))
    minutes, sec = divmod(seconds, 60)
    hours, minutes = divmod(minutes, 60)
    return f"{hours}h {minutes}m {sec}s"


def to_text(value: Any) -> str:
    if value is None:
        return "n/a"
    return str(value)


def load_json(cmd: list[str]) -> Dict[str, Any]:
    return json.loads(run_cmd(cmd))


def load_json_lines(output: str) -> List[Any]:
    items: List[Any] = []
    decoder = json.JSONDecoder()
    for raw in output.splitlines():
        line = raw.strip()
        if not line:
            continue
        try:
            item = json.loads(line)
        except json.JSONDecodeError:
            pos = 0
            while pos < len(line):
                value, pos = decoder.raw_decode(line, pos)
                items.append(value)
                while pos < len(line) and line[pos].isspace():
                    pos += 1
            continue
        if isinstance(item, str):
            item = json.loads(item)
        if isinstance(item, list):
            items.extend(item)
            continue
        if isinstance(item, dict):
            items.append(item)
            continue
        items.append(item)
    return items


def parse_job_items(items: Iterable[Any]) -> List[Dict[str, Any]]:
    jobs: List[Dict[str, Any]] = []
    for item in items:
        if isinstance(item, dict) and isinstance(item.get("jobs"), list):
            jobs.extend(job for job in item["jobs"] if isinstance(job, dict))
        elif isinstance(item, dict):
            jobs.append(item)
    return jobs


def get_arg_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Summarize GitHub Actions run and failed jobs."
    )
    parser.add_argument("run_id", nargs="?", help="GitHub Actions run id")
    parser.add_argument("job_id", nargs="?", help="Target single job id")
    parser.add_argument(
        "--repo",
        default=os.environ.get("GITHUB_REPOSITORY", "saitoha/libsixel"),
        help="owner/repo used for gh api requests",
    )
    parser.add_argument(
        "--download-dir",
        default=".artifacts/action-summarize",
        help="Directory to store downloaded logs and artifacts",
    )
    parser.add_argument(
        "--artifacts",
        action="store_true",
        help="Download failed-job artifacts and parse details from logs",
    )
    parser.add_argument(
        "--jobs",
        type=int,
        default=16,
        help="parallel workers for per-job analysis",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Print final summary as JSON",
    )
    parser.add_argument(
        "--include-cancelled",
        action="store_true",
        help="Also include cancelled jobs in failure analysis",
    )
    parser.add_argument(
        "--self-test",
        action="store_true",
        help=argparse.SUPPRESS,
    )
    return parser


def fail(message: str, code: int = 1) -> None:
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(code)


def fetch_run(repo: str, run_id: str) -> Dict[str, Any]:
    return load_json(["gh", "api", f"repos/{repo}/actions/runs/{run_id}"])


def fetch_jobs(repo: str, run: Dict[str, Any]) -> List[Dict[str, Any]]:
    run_id = str(run["id"])
    attempt = run.get("run_attempt")
    endpoint = f"repos/{repo}/actions/runs/{run_id}/jobs"
    if attempt:
        # GitHub's aggregate jobs endpoint can return HTTP 502 after a run is
        # cancelled and rerun.  The attempt endpoint keeps the summary scoped
        # to the current attempt and avoids mixing stale cancelled jobs with
        # newly scheduled ones.
        endpoint = f"repos/{repo}/actions/runs/{run_id}/attempts/{attempt}/jobs"

    # gh emits each paginated --jq result as a separate JSON value.  Ask jq for
    # one compact job object per line so Python never sees adjacent arrays.
    output = run_cmd(
        [
            "gh",
            "api",
            "--paginate",
            endpoint,
            "--jq",
            ".jobs[] | @json",
        ]
    )
    return parse_job_items(load_json_lines(output))


def fetch_artifacts(repo: str, run_id: str) -> List[Dict[str, Any]]:
    data = load_json(["gh", "api", f"repos/{repo}/actions/runs/{run_id}/artifacts"])
    return data.get("artifacts", [])


def safe_name(name: str) -> str:
    return re.sub(r"[\\/:*?\"<>|]", "_", name)


def download_job_log(repo: str, run_id: str, job_id: int, out_dir: Path) -> Path:
    out_dir.mkdir(parents=True, exist_ok=True)
    log_path = out_dir / f"{job_id}.log"
    if log_path.exists() and log_path.stat().st_size > 0:
        return log_path
    log_text = subprocess.check_output(
        [
            "gh",
            "run",
            "view",
            run_id,
            "--repo",
            repo,
            "--log",
            "--job",
            str(job_id),
        ],
        text=True,
        stderr=subprocess.STDOUT,
    )
    log_path.write_text(log_text)
    return log_path


def normalize_log(text: str) -> str:
    return ANSI_RE.sub("", text)


def clean_log_lines(text: str, patterns: Iterable[str]) -> List[str]:
    keep: List[str] = []
    for line in text.splitlines():
        plain = line.strip()
        if any(pat in plain for pat in patterns):
            keep.append(plain)
    return keep


def filter_log_text_by_step(text: str, step_name: str) -> str:
    if not step_name or step_name == "unknown":
        return text
    keep: List[str] = []
    for line in text.splitlines():
        # gh run view --log prefixes job logs as job<TAB>step<TAB>message.
        parts = line.split("\t", 2)
        if len(parts) >= 3 and parts[1].strip() == step_name:
            keep.append(line)
    if keep:
        return "\n".join(keep)
    return text


def find_failed_step(job: Dict[str, Any], include_cancelled: bool) -> Optional[Dict[str, Any]]:
    steps = job.get("steps") or []
    interest = {"failure", "cancelled", "timed_out"}
    if include_cancelled:
        interest = interest | {"failure", "cancelled", "timed_out"}
    for step in steps:
        conclusion = (step.get("conclusion") or "").lower()
        if conclusion in interest and conclusion != "success":
            return step
    for step in steps:
        if step.get("number") == step.get("number") and step.get("status") == "in_progress":
            return step
    return None


def is_artifact_step(step_name: str, step_conclusion: str) -> bool:
    lower = step_name.lower()
    if step_conclusion in {"", "success", "skipped"}:
        return False
    return "upload" in lower or "artifact" in lower


def is_artifact_log_line(line: str) -> bool:
    lower = line.lower()
    return "upload" in lower or "artifact" in lower


def generic_phase(job_name: str, step_name: str) -> str:
    candidate = f"{job_name} {step_name}".lower()
    if "setup" in candidate or "checkout" in candidate:
        return "workflow/setup"
    if "install" in candidate or "dependency" in candidate or "download" in candidate:
        return "dependency/install"
    if "configure" in candidate or "autogen" in candidate:
        return "configure/setup"
    if "build" in candidate and "artifact" not in candidate:
        return "build"
    if "test" in candidate or "verify" in candidate:
        return "test"
    if "coverage" in candidate:
        return "coverage"
    if "upload" in candidate or "artifact" in candidate:
        return "artifact/upload"
    if "machine" in candidate or "provision" in candidate:
        return "vm/provision"
    return "unknown"


def fuzz_phase(job_name: str, step_name: str) -> str:
    base = f"{job_name} {step_name}".lower()
    if "fuzz" not in base:
        return generic_phase(job_name, step_name)
    if "setup" in base or "install" in base:
        return "fuzz/setup"
    if "build" in base:
        return "fuzz/build"
    if "premerge" in base or "pre-merge" in base or "corpus" in base:
        return "fuzz/corpus-premerge"
    if "artifact" in base or "upload" in base:
        return "fuzz/artifact-upload"
    if "coverage" in base:
        return "fuzz/coverage"
    if "minimize" in base:
        return "fuzz/corpus-minimize"
    if "crash" in base:
        return "fuzz/crash-detect"
    if "run" in base or "fuzz" in base:
        return "fuzz/run"
    return "fuzz/unknown"


def detect_phase(job: Dict[str, Any], step_name: str) -> str:
    job_name = job.get("name", "")
    if "fuzz" in job_name.lower():
        return fuzz_phase(job_name, step_name)
    return generic_phase(job_name, step_name)


def pick_evidence_from_log(
    log_text: str, step_name: str, step_conclusion: str = "failure"
) -> List[str]:
    if not log_text:
        return []
    text = normalize_log(log_text)
    artifact_step = is_artifact_step(step_name, step_conclusion)

    if artifact_step:
        artifact_lines = clean_log_lines(
            text,
            {
                "Multiple search paths detected.",
                "The least common ancestor is",
                "With the provided path, there will be",
                "Upload",
            },
        )[:20]
        if artifact_lines:
            return artifact_lines

    lines = []
    failure_re = re.compile(
        r"(##\[error\]|\bERROR\b|\bFAILED\b|FAIL:|\bFAIL\b|\b[Ee]rror\b|[Ee]rror:)"
    )
    scan_text = text if artifact_step else filter_log_text_by_step(text, step_name)
    for line in scan_text.splitlines():
        plain = line.strip()
        if not artifact_step and is_artifact_log_line(plain):
            continue
        if failure_re.search(plain):
            lines.append(plain)
    if not lines:
        fallback = clean_log_lines(
            scan_text,
            {"FAILED", "ERROR", "error", "FAIL:", "configure", "configuring"},
        )[:20]
        if artifact_step:
            return fallback
        return [line for line in fallback if not is_artifact_log_line(line)]
    return lines[:40]


def parse_testlog(path: Path) -> List[str]:
    try:
        text = path.read_text(errors="ignore").strip()
    except Exception:
        return []
    if not text:
        return []
    try:
        data = json.loads(text)
    except Exception:
        data = []
        for raw in text.splitlines():
            line = raw.strip()
            if not line:
                continue
            try:
                data.append(json.loads(line))
            except Exception:
                return []
    if isinstance(data, list):
        items = data
    elif isinstance(data, dict):
        if "result" in data:
            items = [data]
        else:
            items = data.get("tests", [])
    else:
        items = []
    names: List[str] = []
    for item in items:
        if not isinstance(item, dict):
            continue
        if (item.get("result") or "").upper() in FAILED_TEST_RESULTS:
            name = item.get("name") or item.get("test")
            if name:
                names.append(name)
    return names


def parse_trs(path: Path) -> List[str]:
    lines: List[str] = []
    for raw in path.read_text(errors="ignore").splitlines():
        line = raw.strip()
        marker = ":test-result:"
        if marker not in line:
            continue
        result = line.split(marker, 1)[1].strip().split(None, 1)
        if len(result) != 2:
            continue
        state = result[0].upper()
        test_name = result[1].strip()
        if state in FAILED_TEST_RESULTS and test_name:
            lines.append(test_name)
    return lines


def parse_meson_test_log(path: Path) -> List[str]:
    fail_re = re.compile(r"^(FAIL|ERROR):\s+(.+)$")
    names: List[str] = []
    for line in path.read_text(errors="ignore").splitlines():
        matched = fail_re.search(line)
        if matched:
            names.append(matched.group(2).strip())
    return names


def parse_configure_log(path: Path) -> List[str]:
    return [
        line.strip()
        for line in path.read_text(errors="ignore").splitlines()
        if "configure: error:" in line
        and "failed program was" not in line
    ]


def find_artifacts_for_job(
    artifacts: List[Dict[str, Any]], job_name: str
) -> List[Dict[str, Any]]:
    safe = safe_name(job_name)
    hits: List[Dict[str, Any]] = []
    for art in artifacts:
        name = str(art.get("name") or "")
        if safe in safe_name(name) or name.startswith(safe_name(job_name)[:20]):
            hits.append(art)
    return hits


def download_artifacts(
    repo: str,
    run_id: str,
    job_name: str,
    artifacts: List[Dict[str, Any]],
    base_dir: Path,
) -> List[Path]:
    base_dir.mkdir(parents=True, exist_ok=True)
    paths: List[Path] = []
    matched = find_artifacts_for_job(artifacts, job_name)
    for art in matched:
        name = art.get("name")
        if not name:
            continue
        safe = safe_name(name)
        out_dir = base_dir / "artifacts" / safe
        out_dir.mkdir(parents=True, exist_ok=True)
        manifest = out_dir / ".downloaded"
        if manifest.exists() and manifest.read_text().strip() == name:
            paths.append(out_dir)
            continue
        run_cmd(
            [
                "gh",
                "run",
                "download",
                "--repo",
                repo,
                run_id,
                "--name",
                name,
                "--dir",
                str(out_dir),
            ]
        )
        manifest.write_text(name)
        paths.append(out_dir)
    return paths


def collect_artifact_failures(artifact_dirs: Iterable[Path]) -> List[str]:
    tests: List[str] = []
    logs: List[str] = []
    for root in artifact_dirs:
        for path in root.rglob("*"):
            if not path.is_file():
                continue
            if path.name == "testlog.json":
                tests.extend(parse_testlog(path))
            elif path.suffix == ".trs":
                tests.extend(parse_trs(path))
            elif path.name == "test-suite.log":
                tests.extend(parse_meson_test_log(path))
            elif path.name == "config.log":
                logs.extend(parse_configure_log(path))
    return [f"failed tests: {t}" for t in tests] + [
        f"configure: {line}" for line in logs[:20]
    ]


def summarize_job(
    repo: str,
    run_id: str,
    job: Dict[str, Any],
    args: argparse.Namespace,
    artifacts: List[Dict[str, Any]],
) -> Dict[str, Any]:
    job_id = job.get("id")
    job_name = job.get("name", "unknown")
    conclusion = (job.get("conclusion") or "n/a").lower()
    failed_step = find_failed_step(job, args.include_cancelled)
    failed_step_name = failed_step.get("name") if failed_step else "unknown"
    failed_step_conclusion = (failed_step.get("conclusion") or "").lower() if failed_step else "unknown"
    failed_step_url = failed_step.get("details_url") if failed_step else ""
    phase = detect_phase(job, failed_step_name or "")
    duration = format_time_delta(
        parse_iso8601(job.get("started_at")),
        parse_iso8601(job.get("completed_at")),
    )

    job_dir = (
        Path(args.download_dir)
        / str(run_id)
        / "logs"
    )
    log_path = download_job_log(repo, run_id, int(job_id), job_dir)
    evidence = pick_evidence_from_log(
        log_path.read_text(errors="ignore") if log_path.exists() else "",
        failed_step_name or "",
        failed_step_conclusion,
    )

    artifact_paths: List[str] = []
    evidence_lines: List[str] = list(evidence)
    if args.artifacts and conclusion != "success":
        artifact_dirs = download_artifacts(
            repo, run_id, job_name, artifacts, Path(args.download_dir) / str(run_id)
        )
        artifact_lines = collect_artifact_failures(artifact_dirs)
        for p in artifact_dirs:
            artifact_paths.append(str(p))
        evidence_lines.extend(artifact_lines[:50])

    return {
        "id": job_id,
        "name": job_name,
        "conclusion": conclusion,
        "phase": phase,
        "duration": duration,
        "failed_step": failed_step_name,
        "failed_step_conclusion": failed_step_conclusion,
        "failed_step_url": failed_step_url,
        "evidence": evidence_lines[:120],
        "artifact_paths": artifact_paths,
        "log": str(log_path),
        "duration_seconds": (parse_iso8601(job.get("completed_at")) - parse_iso8601(job.get("started_at"))).total_seconds()
        if parse_iso8601(job.get("completed_at")) and parse_iso8601(job.get("started_at"))
        else None,
    }


def should_analyze(job: Dict[str, Any], args: argparse.Namespace) -> bool:
    if args.job_id:
        return str(job.get("id")) == str(args.job_id)
    if job.get("conclusion") == "failure":
        return True
    if args.include_cancelled and job.get("conclusion") in {"cancelled", "timed_out"}:
        return True
    return False


def self_test() -> int:
    paginated = "\n".join(
        [
            json.dumps({"id": 1, "name": "build"}),
            json.dumps(json.dumps({"id": 2, "name": "test"})),
            json.dumps([{"id": 3, "name": "deploy"}]),
            json.dumps({"jobs": [{"id": 4, "name": "legacy"}]}),
        ]
    )
    jobs = parse_job_items(load_json_lines(paginated))
    if [job.get("id") for job in jobs] != [1, 2, 3, 4]:
        fail("self-test: paginated job parsing failed")

    log_text = "\n".join(
        [
            "FAILED: test_runner",
            "##[error]Process completed with exit code 1.",
            "Upload artifact",
            "##[error]Artifact upload failed",
        ]
    )
    evidence = pick_evidence_from_log(log_text, "Run tests", "failure")
    if any(is_artifact_log_line(line) for line in evidence):
        fail("self-test: normal failure included artifact evidence")
    if not any("FAILED" in line or "error" in line for line in evidence):
        fail("self-test: normal failure missed failure evidence")

    tab_log_text = "\n".join(
        [
            "job\tApply source job env\tthrow new Error('env failed')",
            "job\tRun CI steps\tFAILED: test_runner",
            "job\tRun CI steps\t##[error]Process completed with exit code 1.",
        ]
    )
    evidence = pick_evidence_from_log(tab_log_text, "Run CI steps", "failure")
    if any("Apply source job env" in line for line in evidence):
        fail("self-test: normal failure included another step evidence")
    if not any("Run CI steps" in line and "FAILED" in line for line in evidence):
        fail("self-test: normal failure missed failed step evidence")

    upload = pick_evidence_from_log(log_text, "Upload artifacts", "failure")
    if not any(is_artifact_log_line(line) for line in upload):
        fail("self-test: artifact failure missed artifact evidence")

    with tempfile.TemporaryDirectory(prefix="ls-action-summarize-") as tmpdir:
        tmp = Path(tmpdir)
        trs = tmp / "legacy.trs"
        trs.write_text(
            "\n".join(
                [
                    ":test-result: PASS passing test",
                    ":test-result: SKIP skipped test",
                    ":test-result: XFAIL expected failing test",
                    ":test-result: FAIL failing test name",
                    ":test-result: ERROR crashing test name",
                    ":test-result: TIMEOUT hanging test name",
                    ":test-result: XPASS unexpected pass test",
                ]
            )
        )
        if parse_trs(trs) != [
            "failing test name",
            "crashing test name",
            "hanging test name",
            "unexpected pass test",
        ]:
            fail("self-test: trs failure parsing failed")

        testlog = tmp / "testlog.json"
        testlog.write_text(
            "\n".join(
                [
                    json.dumps({"name": "passing test", "result": "OK"}),
                    json.dumps({"name": "skipped test", "result": "SKIP"}),
                    json.dumps({"name": "failing test", "result": "FAIL"}),
                    json.dumps({"name": "error test", "result": "ERROR"}),
                    json.dumps({"name": "timeout test", "result": "TIMEOUT"}),
                    json.dumps({"name": "xpass test", "result": "XPASS"}),
                ]
            )
        )
        if parse_testlog(testlog) != [
            "failing test",
            "error test",
            "timeout test",
            "xpass test",
        ]:
            fail("self-test: meson json-lines testlog parsing failed")
        artifact_lines = collect_artifact_failures([tmp])
        if "failed tests: failing test" not in artifact_lines:
            fail("self-test: meson json-lines artifact missed failure")
        if "failed tests: xpass test" not in artifact_lines:
            fail("self-test: meson json-lines artifact missed XPASS")

        array_testlog = tmp / "array-testlog.json"
        array_testlog.write_text(
            json.dumps(
                [
                    {"name": "passing array test", "result": "OK"},
                    {"name": "failing array test", "result": "FAIL"},
                ]
            )
        )
        if parse_testlog(array_testlog) != ["failing array test"]:
            fail("self-test: meson array testlog parsing failed")

        object_testlog = tmp / "object-testlog.json"
        object_testlog.write_text(
            json.dumps(
                {
                    "tests": [
                        {"name": "passing object test", "result": "OK"},
                        {"name": "failing object test", "result": "FAIL"},
                    ]
                }
            )
        )
        if parse_testlog(object_testlog) != ["failing object test"]:
            fail("self-test: meson object testlog parsing failed")

        single_object_testlog = tmp / "single-object-testlog.json"
        single_object_testlog.write_text(
            json.dumps({"name": "failing single object test", "result": "FAIL"})
        )
        if parse_testlog(single_object_testlog) != [
            "failing single object test",
        ]:
            fail("self-test: meson single object testlog parsing failed")

        empty_testlog = tmp / "empty-testlog.json"
        empty_testlog.write_text("")
        if parse_testlog(empty_testlog) != []:
            fail("self-test: empty meson testlog parsing failed")

        broken_testlog = tmp / "broken-testlog.json"
        broken_testlog.write_text('{"name": "broken test", "result": "FAIL"')
        if parse_testlog(broken_testlog) != []:
            fail("self-test: broken meson testlog parsing failed")
    print("self-test: ok")
    return 0


def print_summary(run: Dict[str, Any], jobs: List[Dict[str, Any]], results: List[Dict[str, Any]]) -> None:
    statuses = Counter(j.get("conclusion") or "n/a" for j in jobs)
    started = run.get("created_at")
    completed = run.get("completed_at")
    duration = format_time_delta(parse_iso8601(started), parse_iso8601(completed))
    total = len(jobs)
    done = sum(1 for j in jobs if j.get("status") == "completed")
    print(f"Run: {run.get('name', 'n/a')} (#{run.get('id')})")
    print(f"Branch: {run.get('head_branch', 'n/a')}  SHA: {run.get('head_sha', 'n/a')}")
    print(
        "Summary: total={0} success={1} failure={2} cancelled={3} skipped={4} timed_out={5} in_progress={6}".format(
            total,
            statuses.get("success", 0),
            statuses.get("failure", 0),
            statuses.get("cancelled", 0),
            statuses.get("skipped", 0),
            statuses.get("timed_out", 0),
            statuses.get("in_progress", 0),
        )
    )
    print(f"Duration: {duration}  jobs_completed={done}")
    if not results:
        print("Failures: none")
        return

    print(f"\nFailures: {len(results)}")
    for idx, item in enumerate(results, 1):
        title = item["name"]
        if item["id"]:
            title = f"{title} ({item['id']})"
        print(f"[{idx}] {title}")
        print(f"  conclusion: {to_text(item['conclusion'])}")
        print(f"  phase: {item['phase']}")
        print(f"  duration: {item['duration']}")
        print(f"  failed step: {to_text(item['failed_step'])}")
        print(f"  logs: {item['log']}")
        if item["failed_step_url"]:
            print(f"  failed-step-url: {item['failed_step_url']}")
        if item["artifact_paths"]:
            print("  artifact paths:")
            for path in item["artifact_paths"]:
                print(f"    - {path}")
        print("  evidence:")
        for line in item["evidence"]:
            print(f"    - {line}")
        print()


def main() -> int:
    parser = get_arg_parser()
    args = parser.parse_args()
    if args.self_test:
        return self_test()
    if not args.run_id:
        parser.error("the following arguments are required: run_id")
    if not shutil.which("gh"):
        fail("gh is required in PATH")

    Path(args.download_dir).mkdir(parents=True, exist_ok=True)
    run = fetch_run(args.repo, args.run_id)
    all_jobs = fetch_jobs(args.repo, run)
    artifacts = fetch_artifacts(args.repo, args.run_id) if args.artifacts else []

    if args.job_id and all(j.get("id") != int(args.job_id) if str(args.job_id).isdigit() else True for j in all_jobs):
        target = str(args.job_id)
        if not any(str(j.get("id")) == target for j in all_jobs):
            fail(f"job id was not found in run {args.run_id}: {target}")
        fail("invalid job id")

    selected: List[Dict[str, Any]] = []
    for job in all_jobs:
        if should_analyze(job, args):
            selected.append(job)

    results: List[Dict[str, Any]] = []
    if selected:
        with concurrent.futures.ThreadPoolExecutor(max_workers=args.jobs) as pool:
            futures = [
                pool.submit(
                    summarize_job,
                    args.repo,
                    args.run_id,
                    job,
                    args,
                    artifacts,
                )
                for job in selected
            ]
            for future in concurrent.futures.as_completed(futures):
                results.append(future.result())

    ordered = sorted(results, key=lambda item: str(item["id"]))
    if args.json:
        print(json.dumps({"run": run, "jobs": ordered}, indent=2, sort_keys=True))
    else:
        print_summary(run, all_jobs, ordered)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
