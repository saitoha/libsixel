libsixel_la_CPPFLAGS = -I$(top_builddir)/include/ -I$(top_srcdir) $(AM_CPPFLAGS) \
                @THREAD_CPPFLAGS@ $(AMALGAMATION_CPPFLAGS)

libsixel_la_CFLAGS = $(CFLAGS) $(AM_CFLAGS) $(MAYBE_COVERAGE) \
                $(LIBCURL_CFLAGS) \
                $(LIBFETCH_CFLAGS) \
                $(WINHTTP_CFLAGS) \
                $(LIBPNG_CFLAGS) \
                $(LIBTIFF_CFLAGS) \
                $(LIBJPEG_CFLAGS) \
                $(LCMS2_CFLAGS) \
                $(LIBWEBP_CFLAGS) \
                $(LIBRSVG_CFLAGS) \
