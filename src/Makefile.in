maintainer-clean-am: distclean-am maintainer-clean-generic

mostlyclean: mostlyclean-am

mostlyclean-am: mostlyclean-compile mostlyclean-generic \
	mostlyclean-libtool

pdf: pdf-am

pdf-am:

ps: ps-am

ps-am:

uninstall-am: uninstall-libLTLIBRARIES uninstall-man

uninstall-man: uninstall-man5

.MAKE: all check check-am install install-am install-exec \
	install-strip

.PHONY: CTAGS GTAGS TAGS all all-am am--depfiles check check-am \
	check-local clean clean-generic clean-libLTLIBRARIES \
	clean-libtool cscopelist-am ctags ctags-am distclean \
	distclean-compile distclean-generic distclean-libtool \
	distclean-tags distdir dvi dvi-am html html-am info info-am \
	install install-am install-data install-data-am install-dvi \
	install-dvi-am install-exec install-exec-am install-html \
	install-html-am install-info install-info-am \
	install-libLTLIBRARIES install-man install-man5 install-pdf \
	install-pdf-am install-ps install-ps-am install-strip \
	installcheck installcheck-am installdirs maintainer-clean \
	maintainer-clean-generic mostlyclean mostlyclean-compile \
	mostlyclean-generic mostlyclean-libtool pdf pdf-am ps ps-am \
	tags tags-am uninstall uninstall-am uninstall-libLTLIBRARIES \
	uninstall-man uninstall-man5

.PRECIOUS: Makefile


# Keep this recipe tab-indented; GNU make requires tabs for commands.
@WANT_AMALGAMATED_LIB_TRUE@$(AMALGAMATION_SIXEL): $(top_builddir)/amalgamation/Makefile
@WANT_AMALGAMATED_LIB_TRUE@	$(AM_V_GEN)$(MAKE) -C $(top_builddir)/converters completion_embed.h
@WANT_AMALGAMATED_LIB_TRUE@	$(AM_V_GEN)$(MAKE) -C $(top_builddir)/amalgamation $(AMALGAMATION_TARGET)

# Keep this recipe tab-indented; GNU make requires tabs for commands.
@WANT_AMALGAMATED_LIB_TRUE@libsixel_la-sixel.lo: $(AMALGAMATION_SIXEL)
@WANT_AMALGAMATED_LIB_TRUE@	$(AMALGAMATION_COMPILE) -c -o $@ $<

.PHONY: libobjs

# Build only the libtool object set for libsixel.
#
# This target lets the top-level Makefile overlap executable object
# compilation in other directories with the libsixel link step.
libobjs: $(libsixel_la_OBJECTS)

# Keep this recipe tab-indented; GNU make requires tabs for commands.
gen-rgblookup: $(srcdir)/rgblookup.gperf
	gperf -C -N lookup_rgb $(GPERF_OPT) $<  |\
	sed 's/{""}/\{"", 0, 0, 0\}/g'          |\
	astyle                                  > $(srcdir)/rgblookup.h

@WITH_SHEBANG_FILE_TRUE@check-local: $(SIXEL_SHEBANG_STAMP)

# Keep this recipe tab-indented; GNU make requires tabs for commands.
@WITH_SHEBANG_FILE_TRUE@$(SIXEL_SHEBANG_STAMP): $(SIXEL_SHEBANG_TARGETS)
@WITH_SHEBANG_FILE_TRUE@	@if test -n "$(SIXEL_SHEBANG_TARGETS)"; then \
@WITH_SHEBANG_FILE_TRUE@	        $(SIXEL_SHEBANG_HELPER) "$(SIXEL_SHEBANG_FILE)" \
@WITH_SHEBANG_FILE_TRUE@	                $(SIXEL_SHEBANG_TARGETS); \
@WITH_SHEBANG_FILE_TRUE@	fi
@WITH_SHEBANG_FILE_TRUE@	@touch $@

# Tell versions [3.59,3.63) of GNU make to not export all variables.
# Otherwise a system limit (for SysV at least) may be exceeded.
.NOEXPORT:

# Tell GNU make to disable its built-in pattern rules.
%:: %,v
%:: RCS/%,v
%:: RCS/%
%:: s.%
%:: SCCS/s.%
