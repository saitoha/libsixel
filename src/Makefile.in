@BUILDING_ON_WINDOWS_FALSE@libsixel_la_LDFLAGS = -version-info $(LS_LTVERSION) \
@BUILDING_ON_WINDOWS_FALSE@                $(MAYBE_COVERAGE) $(LIBSIXEL_LDFLAGS)

@BUILDING_ON_WINDOWS_TRUE@libsixel_la_LDFLAGS = -no-undefined -version-info $(LS_LTVERSION) \
@BUILDING_ON_WINDOWS_TRUE@                $(MAYBE_COVERAGE) $(LIBSIXEL_LDFLAGS)

libsixel_la_LIBADD = -lm \
                $(LIBCURL_LIBS) \
                $(LIBFETCH_LIBS) \
                $(WINHTTP_LIBS) \
                $(LIBPNG_LIBS) \
                $(LIBTIFF_LIBS) \
                $(LIBJPEG_LIBS) \
