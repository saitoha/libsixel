	$(WINHTTP_CFLAGS) $(LIBPNG_CFLAGS) $(LIBTIFF_CFLAGS) \
	$(LIBJPEG_CFLAGS) $(LCMS2_CFLAGS) $(LIBWEBP_CFLAGS) \
	$(LIBRSVG_CFLAGS) $(GDK_PIXBUF_CFLAGS) $(GD_CFLAGS) \
	$(WIC_CFLAGS) $(COREGRAPHICS_CFLAGS) $(QUICKLOOK_CFLAGS) \
	$(CLIPBOARD_CFLAGS) @THREAD_CFLAGS@ $(am__append_2)
AMALGAMATION_LSQA_LIBS = -lm \
        $(LIBCURL_LIBS) \
        $(WINHTTP_LIBS) \
        $(LIBPNG_LIBS) \
        $(LIBTIFF_LIBS) \
        $(LIBJPEG_LIBS) \
        $(LCMS2_LIBS) \
        $(LIBWEBP_LIBS) \
        $(LIBRSVG_LIBS) \
        $(GDK_PIXBUF_LIBS) \
        $(GD_LIBS) \
        $(WIC_LIBS) \
        $(COREGRAPHICS_LIBS) \
        $(QUICKLOOK_LIBS) \
        $(CLIPBOARD_LIBS) \
        @THREAD_LIBS@

