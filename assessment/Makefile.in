@WANT_AMALGAMATED_TOOLS_FALSE@	$(WIC_LIBS) $(COREGRAPHICS_LIBS) \
@WANT_AMALGAMATED_TOOLS_FALSE@	$(QUICKLOOK_LIBS) \
@WANT_AMALGAMATED_TOOLS_FALSE@	$(CLIPBOARD_LIBS) @THREAD_LIBS@
